<view class="ai-card">
  <view class="ai-card__title">养老金测算结果</view>
  <view wx:if="{{province}}" class="ai-card__prov">{{province}}</view>

  <view class="ai-card__row">
    <text class="ai-card__label">预计退休时间</text>
    <text class="ai-card__value">{{retireDate}}</text>
  </view>
  <view class="ai-card__row">
    <text class="ai-card__label">退休年龄</text>
    <text class="ai-card__value">{{retireAge}}</text>
  </view>
  <view class="ai-card__row">
    <text class="ai-card__label">每月养老金</text>
    <text class="ai-card__value">¥{{monthlyPension}}</text>
  </view>

  <view class="ai-card__note">数据基于官方社平/计发基数，仅供参考，不作待遇核定依据</view>
</view>
