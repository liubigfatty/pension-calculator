<!--pages/result/result.wxml - 卡片式设计 v2-->
<view class="container">

  <!-- 三路条件：分享查看 / 数据异常 / 正常结果 -->
  <block wx:if="{{isShareView}}">

    <!-- 分享查看模式：显示分享者的结果 -->
    <view class="amount-card">
      <text class="amount-card-label">每月可领取养老金</text>
      <view class="amount-card-row">
        <text class="amount-card-symbol">¥</text>
        <text class="amount-card-value">{{totalAmount || '--'}}</text>
      </view>
      <view class="retire-tag" wx:if="{{retireAge}}">
        <text>{{retireAge}}{{retirementType === 'early' ? '弹性提前退休' : '法定年龄退休'}}</text>
      </view>
    </view>

    <text class="region-text" wx:if="{{provinceName || cityLabel}}">{{provinceName}}{{cityLabel ? ' · ' + cityLabel : ''}}</text>

    <view class="btn-area">
      <button class="btn-calculate" bindtap="goCalculate">我也来算一下</button>
    </view>

    <view class="disclaimer">
      <text>以上为分享者的测算结果，实际待遇以社保部门核定为准</text>
    </view>
  </block>

  <block wx:elif="{{!hasValidData}}">

    <!-- 数据异常提示 -->
    <view class="error-tip">
      <view class="error-icon">⚠️</view>
      <text class="error-title">未获取到计算结果</text>
      <text class="error-desc">{{errorMsg || '请返回并重新计算'}}</text>
      <button class="btn-recalc" bindtap="onRecalculate">返回重新计算</button>
    </view>
  </block>

  <block wx:else>

    <!-- 正常结果展示 -->
    <view class="amount-card">
      <text class="amount-card-label">每月可领取养老金</text>
      <view class="amount-card-row">
        <text class="amount-card-symbol">¥</text>
        <text class="amount-card-value">{{totalAmount != null ? totalAmount : '--'}}</text>
      </view>
      <view class="retire-tag" wx:if="{{retireInfo}}">
        <text>{{retireInfo}}</text>
      </view>
    </view>

    <text class="region-text" wx:if="{{provinceName || cityLabel}}">{{provinceName}}{{cityLabel ? ' · ' + cityLabel : ''}}</text>

    <view class="card">
      <view class="card-body">
        <view class="card-row">
          <text class="card-label">基础养老金</text>
          <text class="card-value">{{basePension != null ? '¥' + basePension : '--'}}</text>
        </view>
        <view class="card-row" wx:if="{{transitionPension != null && transitionPension > 0}}">
          <text class="card-label">过渡性养老金</text>
          <text class="card-value">¥{{transitionPension}}</text>
        </view>
        <view class="card-row">
          <text class="card-label">个人账户养老金</text>
          <text class="card-value">{{personalPension != null ? '¥' + personalPension : '--'}}</text>
        </view>
        <view class="card-row" wx:if="{{extraPension != null && extraPension > 0}}">
          <text class="card-label">其它加发</text>
          <text class="card-value">¥{{extraPension}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-body">
        <view class="card-divider"></view>
        <view class="card-row">
          <text class="card-label">累计缴费年限</text>
          <text class="card-value">{{workYears != null ? workYears + ' 年' : '--'}}</text>
        </view>
        <view class="card-row">
          <text class="card-label">实际缴费年限</text>
          <text class="card-value">{{actualYears != null ? actualYears + ' 年' : '--'}}</text>
        </view>
        <view class="card-row" wx:if="{{sameYears != null && sameYears > 0}}">
          <text class="card-label">视同缴费年限</text>
          <text class="card-value">{{sameYears}} 年</text>
        </view>
        <view class="card-divider"></view>
        <view class="card-row">
          <text class="card-label">平均缴费指数</text>
          <text class="card-value">{{averageIndex != null ? averageIndex : '--'}}</text>
        </view>
        <view class="card-row">
          <text class="card-label">个人账户余额</text>
          <text class="card-value">{{accountBalance != null ? accountBalance + ' 元' : '--'}}</text>
        </view>
        <view class="card-row">
          <text class="card-label">计发月数</text>
          <text class="card-value">{{months != null ? months : '--'}}</text>
        </view>
        <view class="card-row">
          <text class="card-label">退休地计发基数</text>
          <text class="card-value">{{baseNumber || '--'}}</text>
        </view>
      </view>
    </view>

    <view class="btn-area">
      <button class="btn-share" bindtap="onShareResult">分享结果</button>
      <button class="btn-report" bindtap="goReport">查看详细退休计划报告</button>
    </view>

    <view class="disclaimer">
      <text>计算结果仅供参考，实际待遇以社保部门核定为准</text>
    </view>

    <wxml-to-canvas class="shareWidget" width="375" height="700" style="position:absolute;left:-9999px;top:0;"></wxml-to-canvas>
  </block>
</view>
