/* pages/result/result.wxss - 澧炲己鐗?v3锛堢簿鑷撮噾铻嶉鏍硷級 */

.container {
  padding: 32rpx;
  background: #F5F3F0;  /* 姝ｅ厓鏆栫櫧 - 椤甸潰搴?*/
  min-height: 100vh;
}

/* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?閲戦涓诲崱鐗囷紙绮捐嚧娓愬彉锛?鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
.amount-card {
  background: linear-gradient(165deg, #171717 0%, #2A2A2A 100%);  /* 绮捐嚧娣辫壊娓愬彉 */
  border-radius: 32rpx;  /* 鏇村ぇ鐨勫渾瑙?*/
  padding: 56rpx 40rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(40,41,43,0.25),  /* 涓婚槾褰?*/
    0 2rpx 8rpx rgba(40,41,43,0.15),   /* 娆￠槾褰?*/
    inset 0 1rpx 0 rgba(139,115,85,0.12);  /* 椤堕儴楂樺厜 */
  position: relative;
  overflow: hidden;
}

/* 娣诲姞 subtle 绾圭悊鑳屾櫙 */
.amount-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 40%, rgba(139,115,85,0.06) 0%, transparent 60%);
  pointer-events: none;
}

.amount-card-label {
  font-size: 28rpx;
  color: rgba(139,115,85,0.9);  /* 姝ｅ厓鍏?- 鍗婇€忔槑 */
  letter-spacing: 2rpx;
  font-weight: 400;
  margin-bottom: 8rpx;
}

.amount-card-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin: 24rpx 0 16rpx;
}

.amount-card-symbol {
  font-size: 48rpx;
  color: #B8977D;  /* 姝ｅ厓鍏?- 閲戣壊 */
  font-weight: 600;
  margin-right: 8rpx;
}

.amount-card-value {
  font-size: 96rpx;  /* 鏇村ぇ鐨勯噾棰?*/
  color: #B8977D;  /* 姝ｅ厓鍏?- 閲戣壊 */
  font-weight: 700;  /* 鏇寸矖鐨勫瓧閲?*/
  line-height: 1;
  letter-spacing: -3rpx;  /* 鏇寸揣鍑戠殑瀛楁瘝闂磋窛 */
  font-family: -apple-system, 'Helvetica Neue', 'PingFang SC', sans-serif;
}

/* 閫€浼戜俊鎭爣绛?*/
.retire-tag {
  margin-top: 24rpx;
  background: rgba(139,115,85,0.12);  /* 鍗婇€忔槑閲戣壊 */
  border-radius: 48rpx;
  padding: 12rpx 32rpx;
  border: 1rpx solid rgba(139,115,85,0.18);  /* 绮捐嚧杈规 */
}

.retire-tag text {
  font-size: 26rpx;
  color: rgba(139,115,85,0.95);  /* 姝ｅ厓鍏?*/
  font-weight: 500;
}

/* 鍦板尯鏍囩 */
.region-text {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #6C584B;  /* Warm Taupe - 鏆栨 */
  margin: 8rpx 0 28rpx;
  letter-spacing: 1rpx;
}

/* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?閫氱敤鍗＄墖鏍峰紡锛堝寮猴級 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
.card {
  background: #F4F0E8;  /* Creamy Off-White - 鏆栫櫧 */
  border-radius: 32rpx;  /* 缁熶竴澶у崱鐗囧渾瑙?*/
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 
    0 4rpx 16rpx rgba(40,41,43,0.06),  /* 涓婚槾褰?*/
    0 1rpx 4rpx rgba(40,41,43,0.04);   /* 娆￠槾褰?*/
  border: 1rpx solid rgba(213,206,195,0.5);  /* 绮捐嚧瀵岃川鎰熻竟妗?*/
}

.card-body {
  padding: 20rpx 36rpx;  /* 缁熶竴琛岄棿璺?*/
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;  /* 缁熶竴琛岄棿璺?*/
  min-height: 56rpx;
}

.card-label {
  font-size: 28rpx;
  color: #6C584B;  /* Warm Taupe - 鏆栨 */
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.card-value {
  font-size: 32rpx;  /* 鏇村ぇ鐨勬暟鍊?*/
  color: #171717;  /* Deep Charcoal - 娣辫壊姝ｆ枃 */
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.card-value-blue {
  color: #8B7355;  /* 姝ｅ厓閲?*/
  font-weight: 600;
}

.card-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #E0D8CC 15%, #E0D8CC 85%, transparent 100%);  /* 娓愬彉鍒嗗壊绾?*/
  margin: 0;
}

/* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?鎸夐挳鍖哄煙锛堝寮猴級 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
.btn-area {
  padding: 16rpx 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 12rpx;
}

.btn-share {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(139,115,85,0.35);
}

.btn-share::after { border: none; }

.btn-report {
  width: 100%;
  background: #F4F0E8;
  color: #8B7355 !important;
  border: 2rpx solid #8B7355;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.btn-report::after { border: none; }

/* 鍒嗕韩鏌ョ湅妯″紡锛?鎴戜篃鏉ョ畻涓€涓?鎸夐挳 */
.btn-calculate {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(139,115,85,0.35);
}

.btn-calculate::after { border: none; }

.error-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx 80rpx;
  min-height: 60vh;
  text-align: center;
}

.error-icon { font-size: 80rpx; margin-bottom: 32rpx; }

.error-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #171717;  /* Deep Charcoal - 娣辫壊姝ｆ枃 */
  margin-bottom: 24rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #6C584B;  /* Warm Taupe - 鏆栨 */
  line-height: 1.6;
  margin-bottom: 48rpx;
}

/* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?澹版槑 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
.disclaimer {
  padding: 32rpx 16rpx 56rpx;
  text-align: center;
}

.disclaimer text {
  font-size: 24rpx;
  color: #AAAAAA;
}
/* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲 鍒嗕韩棰勮寮圭獥 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲 */
.share-preview-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.share-preview-body {
  width: 100%;
  max-height: 90vh;
  background: #F5F3F0;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.share-preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #E0D8CC;
}

.share-preview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #171717;
}

.share-preview-close {
  font-size: 40rpx;
  color: #6C584B;
  padding: 8rpx 16rpx;
}

.share-preview-scroll {
  flex: 1;
  max-height: 60vh;
  padding: 24rpx 32rpx;
}

.share-preview-img {
  width: 100%;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(40,41,43,0.10);
}

.share-preview-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 48rpx;
  border-top: 1rpx solid #E0D8CC;
}

.share-preview-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
}

.share-preview-btn::after { border: none; }


.share-preview-btn.share {
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(139,115,85,0.35);
}
