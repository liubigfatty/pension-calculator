/* */

.container {
  padding: 32rpx;
  background: #F5F3F0;  /* */
  min-height: 100vh;
}

/* */
.amount-card {
  background: linear-gradient(165deg, #171717 0%, #2A2A2A 100%);  /* */
  border-radius: 32rpx;  /* */
  padding: 56rpx 40rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(40,41,43,0.25),  /* */
    0 2rpx 8rpx rgba(40,41,43,0.15),   /* */
    inset 0 1rpx 0 rgba(139,115,85,0.12);  /* */
  position: relative;
  overflow: hidden;
}

/* */
.amount-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 40%, rgba(139,115,85,0.06) 0%, transparent 60%);
  pointer-events: none;
}

.amount-card-label {
  font-size: 28rpx;
  color: rgba(139,115,85,0.9);  /* */
  letter-spacing: 2rpx;
  font-weight: 400;
  margin-bottom: 8rpx;
}

.amount-card-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin: 24rpx 0 16rpx;
}

.amount-card-symbol {
  font-size: 48rpx;
  color: #B8977D;  /* */
  font-weight: 600;
  margin-right: 8rpx;
}

.amount-card-value {
  font-size: 96rpx;  /* */
  color: #B8977D;  /* */
  font-weight: 700;  /* */
  line-height: 1;
  letter-spacing: -3rpx;  /* */
  font-family: -apple-system, 'Helvetica Neue', 'PingFang SC', sans-serif;
}

/* */
.retire-tag {
  margin-top: 24rpx;
  background: rgba(139,115,85,0.12);  /* */
  border-radius: 48rpx;
  padding: 12rpx 32rpx;
  border: 1rpx solid rgba(139,115,85,0.18);  /* */
}

.retire-tag text {
  font-size: 26rpx;
  color: rgba(139,115,85,0.95);  /* */
  font-weight: 500;
}

/* */
.region-text {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #6C584B;  /* */
  margin: 8rpx 0 28rpx;
  letter-spacing: 1rpx;
}

/* */
.card {
  background: #F4F0E8;  /* */
  border-radius: 32rpx;  /* */
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 
    0 4rpx 16rpx rgba(40,41,43,0.06),  /* */
    0 1rpx 4rpx rgba(40,41,43,0.04);   /* */
  border: 1rpx solid rgba(213,206,195,0.5);  /* */
}

.card-body {
  padding: 20rpx 36rpx;  /* */
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;  /* */
  min-height: 56rpx;
}

.card-label {
  font-size: 28rpx;
  color: #6C584B;  /* */
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.card-value {
  font-size: 32rpx;  /* */
  color: #171717;  /* */
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.card-value-blue {
  color: #8B7355;  /* */
  font-weight: 600;
}

.card-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #E0D8CC 15%, #E0D8CC 85%, transparent 100%);  /* */
  margin: 0;
}

/* */
.btn-area {
  padding: 16rpx 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 12rpx;
}

.btn-share {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(139,115,85,0.35);
}

.btn-share::after { border: none; }

.btn-report {
  width: 100%;
  background: #F4F0E8;
  color: #8B7355 !important;
  border: 2rpx solid #8B7355;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.btn-report::after { border: none; }

/* */
.btn-calculate {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(139,115,85,0.35);
}

.btn-calculate::after { border: none; }

.error-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx 80rpx;
  min-height: 60vh;
  text-align: center;
}

.error-icon { font-size: 80rpx; margin-bottom: 32rpx; }

.error-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #171717;  /* */
  margin-bottom: 24rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #6C584B;  /* */
  line-height: 1.6;
  margin-bottom: 48rpx;
}

/* */
.disclaimer {
  padding: 32rpx 16rpx 56rpx;
  text-align: center;
}

.disclaimer text {
  font-size: 24rpx;
  color: #AAAAAA;
}
