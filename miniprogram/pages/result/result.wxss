.page { padding-bottom: 100px; }

.result-header { text-align: center; padding: 32px 16px 16px; }
.result-label { font-size: 14px; color: #86868b; }
.result-amount { font-size: 42px; font-weight: 700; color: #0071e3; display: block; margin-top: 4px; }

.tab-bar { display: flex; gap: 12px; margin: 0 16px; }
.tab-item {
  flex: 1; text-align: center; padding: 14px; border-radius: 12px;
  background: #fff; border: 1.5px solid #e5e5ea;
}
.tab-item.active { border-color: #0071e3; }
.tab-label { font-size: 13px; color: #86868b; display: block; }
.tab-amount { font-size: 20px; font-weight: 700; color: #1d1d1f; display: block; margin-top: 4px; }
.tab-item.active .tab-amount { color: #0071e3; }

.info-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #f0f0f0; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 14px; color: #86868b; }
.info-value { font-size: 16px; font-weight: 600; }
.info-value.highlight { color: #ff3b30; }
