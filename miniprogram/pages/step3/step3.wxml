<!--pages/step3/step3.wxml - 优化版（去掉多余提示）-->
<view class="step-container">
  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-step done">
      <view class="step-dot">1</view>
      <text class="step-label">选择地区</text>
    </view>
    <view class="step-line active"></view>
    <view class="progress-step done">
      <view class="step-dot">2</view>
      <text class="step-label">个人信息</text>
    </view>
    <view class="step-line active"></view>
    <view class="progress-step active">
      <view class="step-dot">3</view>
      <text class="step-label">缴费信息</text>
    </view>
  </view>

  <!-- 标题 -->
  <text class="page-title">缴费信息</text>
  <text class="page-desc">请填写缴费相关信息</text>

  <!-- 平均缴费指数 -->
  <view class="form-group">
    <text class="form-label"><text class="form-required">*</text> 平均缴费指数</text>
    <view class="index-grid">
      <view
        wx:for="{{indexOptions}}"
        wx:key="value"
        class="index-item {{selectedIndex === index && !useCustomIndex ? 'active' : ''}}"
        data-idx="{{index}}"
        bindtap="onIndexSelect"
      >{{item.label}}</view>
    </view>
    <view class="custom-index" bindtap="onCustomIndexTap">
      <text class="{{useCustomIndex ? 'active' : ''}}">{{useCustomIndex ? '✏️ 手动输入中...' : '✏️ 手动输入'}}</text>
    </view>
    <input
      wx:if="{{useCustomIndex}}"
      class="custom-input"
      type="digit"
      placeholder="0.6 ~ 3.0"
      value="{{customIndex}}"
      bindinput="onIndexInput"
    />
  </view>

  <!-- 个人账户余额 -->
  <view class="form-group">
    <text class="form-label"><text class="form-required">*</text> 个人账户余额（元）</text>
    <input
      class="balance-input"
      type="digit"
      placeholder="请输入个人账户余额"
      value="{{accountBalance}}"
      bindinput="onBalanceInput"
    />
  </view>

  <!-- 加发项（按参保地动态显示，对齐引擎扁平字段） -->
  <view class="form-group" wx:if="{{showExtra}}">
    <text class="form-label">加发项（{{provinceName}}）</text>

    <!-- 四川：增发比例 -->
    <view wx:if="{{provSlug === 'sichuan'}}" class="extra-item">
      <text class="extra-label">增发养老金比例</text>
      <input class="balance-input" type="digit" placeholder="如 0.003（即 0.3%）" value="{{exExtraRate}}" bindinput="onExtraRate" />
      <text class="extra-hint">独生子女 0.1% ＋ 艰苦边远 0.1% 等，合计约 0.1%~0.4%</text>
    </view>

    <!-- 宁夏：知识分子 -->
    <view wx:if="{{provSlug === 'ningxia'}}" class="extra-switch">
      <text class="extra-label">属于知识分子（工龄＋地区补贴）</text>
      <switch checked="{{exIntellectual}}" bindchange="onIntellectualToggle" color="#07c160" />
    </view>

    <!-- 云南/重庆/海南：独生子女 -->
    <view wx:if="{{provSlug === 'yunnan' || provSlug === 'chongqing' || provSlug === 'hainan'}}" class="extra-switch">
      <text class="extra-label">持有《独生子女父母光荣证》</text>
      <switch checked="{{exOneChild}}" bindchange="onOneChildToggle" color="#07c160" />
    </view>

    <!-- 云南：补贴基数选填 -->
    <view wx:if="{{provSlug === 'yunnan' && exOneChild}}" class="extra-item">
      <text class="extra-label">独生子女补贴基数（选填）</text>
      <input class="balance-input" type="digit" placeholder="全省人均养老金，留空自动取" value="{{exOneChildAvg}}" bindinput="onOneChildAvg" />
    </view>

    <!-- 海南：独生子女类型 -->
    <view wx:if="{{provSlug === 'hainan' && exOneChild}}" class="extra-item">
      <text class="extra-label">独生子女类型</text>
      <picker range="{{oneChildTypeLabels}}" value="{{exOneChildTypeIdx}}" bindchange="onOneChildTypeChange">
        <view class="extra-picker">{{oneChildTypeLabels[exOneChildTypeIdx]}}</view>
      </picker>
    </view>

    <!-- 西藏：在藏工作年限 -->
    <view wx:if="{{provSlug === 'xizang'}}" class="extra-item">
      <text class="extra-label">在藏工作年限（年）</text>
      <input class="balance-input" type="digit" placeholder="满10年5% / 满15年10% / 满20年15%" value="{{exTibetYears}}" bindinput="onTibetYears" />
      <text class="extra-hint">地区类别默认二类地区（拉萨）</text>
    </view>
  </view>

  <!-- 计算按钮 -->
  <view class="btn-area">
    <button class="btn-secondary" bindtap="onPrev">上一步</button>
    <button class="btn-calculate" bindtap="onCalculate">计算养老金</button>
  </view>
</view>
