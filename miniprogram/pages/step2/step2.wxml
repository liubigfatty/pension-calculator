<!--pages/step2/step2.wxml - 缴费信息页（新 step2）-->
<view class="step-container">
  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-step done">
      <view class="step-dot">1</view>
      <text class="step-label">测算</text>
    </view>
    <view class="step-line done"></view>
    <view class="progress-step done">
      <view class="step-dot">2</view>
      <text class="step-label">个人信息</text>
    </view>
    <view class="step-line active"></view>
    <view class="progress-step active">
      <view class="step-dot">3</view>
      <text class="step-label">缴费信息</text>
    </view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">
    <view class="form-card-header">
      <view class="form-card-num">①</view>
      <text class="form-card-title">缴费信息</text>
    </view>

    <!-- 缴费基数类型 -->
    <view class="form-item">
      <text class="form-label"><text class="form-required">*</text> 缴费基数类型</text>
      <picker mode="selector" range="{{baseTypeNames}}" value="{{baseTypeIndex}}" bindchange="onBaseTypeChange" class="form-picker">
        <view class="picker-content {{baseTypeIndex >= 0 ? '' : 'placeholder'}}">{{baseTypeIndex >= 0 ? baseTypeNames[baseTypeIndex] : '请选择基数类型'}}</view>
        <text class="picker-arrow">▼</text>
      </picker>
    </view>

    <!-- 缴费档次（灵活就业） -->
    <view class="form-item" wx:if="{{baseTypeIndex == 1}}">
      <text class="form-label">缴费档次（灵活就业）</text>
      <picker mode="selector" range="{{levelNames}}" value="{{levelIndex}}" bindchange="onLevelChange" class="form-picker">
        <view class="picker-content {{levelIndex >= 0 ? '' : 'placeholder'}}">{{levelIndex >= 0 ? levelNames[levelIndex] : '请选择缴费档次'}}</view>
        <text class="picker-arrow">▼</text>
      </picker>
    </view>

    <!-- 历年缴费指数（按实际缴费指数） -->
    <view class="form-item" wx:if="{{baseTypeIndex == 2}}">
      <text class="form-label">历年缴费指数</text>
      <view class="input-row">
        <input class="input-box" type="digit" value="{{averageIndexInput}}" placeholder="0.6~3.0" bindinput="onIndexInput"/>
        <text class="input-unit">指数</text>
      </view>
    </view>

    <!-- 双指数省份（浙江/广东/陕西）- 并排显示 -->
    <view class="form-item" wx:if="{{showDoubleIndex && baseTypeIndex == 2}}">
      <text class="form-label">双指数省份（过渡性养老金指数）</text>
      <view class="double-index-row">
        <view class="input-row flex-1">
          <input class="input-box" type="digit" value="{{transIndexInput}}" placeholder="过渡性指数" bindinput="onTransIndexInput"/>
          <text class="input-unit">过渡指数</text>
        </view>
        <view class="input-row flex-1">
          <input class="input-box" type="digit" value="{{oldIndexInput}}" placeholder="老办法指数" bindinput="onOldIndexInput"/>
          <text class="input-unit">老办法指数</text>
        </view>
      </view>
    </view>

    <!-- 个人账户余额 -->
    <view class="form-item">
      <text class="form-label"><text class="form-required">*</text> 个人账户余额（估算）</text>
      <view class="input-row">
        <input class="input-box" type="digit" value="{{accountBalanceInput}}" placeholder="请输入余额" bindinput="onBalanceInput"/>
        <text class="input-unit">元</text>
      </view>
      <text class="form-hint">不清楚可查看【小贴士】</text>
    </view>

    <!-- 计算按钮 -->
    <button class="btn-submit" bindtap="onCalculate">计算养老金</button>
  </view>

  <!-- 返回按钮 -->
  <view class="btn-back-wrap">
    <button class="btn-back" bindtap="onPrev">← 返回上一步</button>
  </view>
</view>
