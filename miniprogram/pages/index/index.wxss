.page {
  padding-bottom: 100px;
}

/* 步骤进度条 */
.step-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px 16px 8px;
  position: relative;
}
.step-dot {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: #e5e5ea;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}
.step-dot.active { background: #0071e3; }
.step-dot.current { background: #0071e3; box-shadow: 0 0 0 3px rgba(0,113,227,.2); }
.dot-num { font-size: 12px; color: #fff; font-weight: 600; }

/* 步骤内容 */
.step-swiper { height: 70vh; }
.step-title { font-size: 20px; font-weight: 700; display: block; margin-bottom: 6px; }
.step-desc { font-size: 14px; color: #86868b; display: block; margin-bottom: 16px; }

/* 身份选择 */
.employ-grid { display: flex; gap: 12px; margin-top: 16px; }
.employ-card {
  flex: 1; padding: 20px 12px; border-radius: 12px;
  border: 2px solid #e5e5ea; text-align: center;
}
.employ-card.active { border-color: #0071e3; background: #f0f7ff; }
.employ-icon { font-size: 32px; display: block; }
.employ-label { font-size: 16px; font-weight: 600; display: block; margin-top: 8px; }
.employ-desc { font-size: 12px; color: #86868b; display: block; margin-top: 4px; }

/* 性别选择 */
.gender-section { margin-top: 20px; }
.section-label { font-size: 15px; font-weight: 600; display: block; margin-bottom: 10px; }
.gender-grid { display: flex; gap: 10px; }
.gender-card {
  flex: 1; padding: 14px; border-radius: 10px;
  border: 1.5px solid #e5e5ea; text-align: center; font-size: 15px;
}
.gender-card.active { border-color: #0071e3; background: #f0f7ff; color: #0071e3; font-weight: 600; }

/* 表单字段 */
.field-group { margin-top: 20px; }
.field-label { font-size: 15px; font-weight: 600; display: block; margin-bottom: 8px; color: #1d1d1f; }
.picker-row { display: flex; gap: 12px; }
.picker-box {
  flex: 1; height: 44px; line-height: 44px; padding: 0 14px;
  border: 1px solid #e5e5ea; border-radius: 10px; font-size: 15px;
}
.custom-input {
  height: 44px; line-height: 44px; padding: 0 14px;
  border: 1px solid #e5e5ea; border-radius: 10px; font-size: 15px;
}

/* 缴费水平 */
.pay-grid { display: flex; gap: 10px; margin-top: 16px; }
.pay-card {
  flex: 1; padding: 18px 8px; border-radius: 12px;
  border: 2px solid #e5e5ea; text-align: center;
}
.pay-card.active { border-color: #0071e3; background: #f0f7ff; }
.pay-pct { font-size: 22px; font-weight: 700; display: block; }
.pay-label { font-size: 13px; color: #86868b; display: block; margin-top: 4px; }
.divider-text { text-align: center; font-size: 13px; color: #86868b; margin: 16px 0; }

/* 特殊标记 */
.special-grid { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; }
.special-card {
  padding: 12px 20px; border-radius: 10px;
  border: 1.5px solid #e5e5ea; font-size: 15px;
}
.special-card.active { border-color: #0071e3; background: #f0f7ff; color: #0071e3; font-weight: 600; }

/* 导航按钮 */
.nav-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; gap: 12px; padding: 12px 16px;
  background: #f5f5f7; border-top: 1px solid #e5e5ea;
}
.nav-btn {
  flex: 1; height: 48px; line-height: 48px; text-align: center;
  border-radius: 12px; font-size: 16px; font-weight: 600;
}
.nav-btn.prev { background: #e5e5ea; color: #1d1d1f; }
.nav-btn.next { background: #0071e3; color: #fff; }

.loading-tip { text-align: center; padding: 20px; color: #86868b; font-size: 14px; }
