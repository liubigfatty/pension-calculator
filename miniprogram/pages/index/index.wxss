/* pages/index/index.wxss - 优化版（更紧凑）*/

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: var(--space-md);  /* 缩小padding */
}

/* 主视觉区域 */
.hero {
  width: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;  /* 缩小顶部间距 */
  padding-bottom: 40rpx;  /* 缩小底部间距 */
}

.logo-img {
  width: 320rpx;  /* 缩小logo */
  height: 240rpx;  /* 缩小logo */
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3);  /* 缩小阴影 */
}

.hero-overlay {
  margin-top: var(--space-md);  /* 缩小margin */
  text-align: center;
}

.brand-name {
  display: block;
  font-size: var(--font-size-xxl);  /* 48rpx（原来56rpx） */
  font-weight: var(--font-weight-bold);
  color: var(--color-text-white);
  letter-spacing: 4rpx;  /* 缩小字间距 */
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);  /* 缩小阴影 */
}

.brand-slogan {
  display: block;
  margin-top: var(--space-sm);  /* 缩小margin */
  font-size: var(--font-size-base);  /* 28rpx（原来26rpx，略增大提高可读性） */
  color: rgba(255,255,255,0.75);
  letter-spacing: 1rpx;  /* 缩小字间距 */
}

.brand-tagline {
  display: block;
  margin-top: var(--space-xs);  /* 缩小margin */
  font-size: var(--font-size-sm);  /* 24rpx（原来22rpx，略增大） */
  color: rgba(7,193,96,0.9);
  font-weight: var(--font-weight-medium);
  letter-spacing: 0.5rpx;  /* 缩小字间距 */
}

/* 核心优势 - 优化：更紧凑 */
.advantages {
  width: 90%;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-xl);
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: var(--space-lg) var(--space-md);  /* 缩小padding */
  margin-top: var(--space-xl);  /* 缩小margin */
  backdrop-filter: blur(10px);
}

.adv-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.adv-num {
  font-size: var(--font-size-xl);  /* 40rpx（原来44rpx） */
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.adv-label {
  font-size: var(--font-size-sm);  /* 24rpx（原来26rpx） */
  color: rgba(255,255,255,0.85);
  margin-top: var(--space-xs);  /* 缩小margin */
}

.adv-sub {
  font-size: var(--font-size-xs);  /* 20rpx（原来22rpx） */
  color: rgba(255,255,255,0.5);
  margin-top: 2rpx;  /* 缩小margin */
}

.adv-divider {
  width: 1rpx;
  height: 60rpx;  /* 缩小高度 */
  background: rgba(255,255,255,0.15);
}

/* 开始按钮 - 优化：更紧凑 */
.btn-start {
  width: 75%;  /* 缩小宽度（原来85%） */
  margin-top: var(--space-xl);  /* 缩小margin */
}

.btn-text { 
  letter-spacing: 4rpx;  /* 缩小字间距 */
}

.btn-arrow { 
  font-size: 36rpx;  /* 缩小箭头（原来44rpx） */
  line-height: 1; 
}

/* 底部说明 - 优化：更紧凑 */
.footer {
  position: fixed;
  bottom: var(--space-md);  /* 缩小底部间距 */
  left: 0;
  right: 0;
  text-align: center;
  padding: 0 var(--space-xl);  /* 缩小左右padding */
}

.footer-text {
  font-size: var(--font-size-xs);  /* 20rpx（原来22rpx） */
  color: rgba(255,255,255,0.35);
}

/* 隐私协议弹窗 - 优化：更紧凑 */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.privacy-popup {
  width: 80%;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl) var(--space-xl);  /* 缩小padding */
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3);  /* 缩小阴影 */
}

.privacy-title {
  font-size: var(--font-size-lg);  /* 36rpx（原来38rpx） */
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: var(--space-xl);  /* 缩小margin */
}

.privacy-content {
  font-size: var(--font-size-base);  /* 28rpx（原来30rpx） */
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
  margin-bottom: var(--space-xl);  /* 缩小margin */
  text-align: justify;
}

.privacy-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);  /* 缩小间距 */
}

.privacy-btn-view {
  background: var(--color-bg-input);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-round);
  font-size: var(--font-size-base);  /* 28rpx（原来30rpx） */
  padding: var(--space-sm) 0;  /* 缩小padding */
}

.privacy-btn-disagree {
  background: var(--color-bg-card);
  color: var(--color-text-hint);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-round);
  font-size: var(--font-size-base);  /* 28rpx（原来30rpx） */
  padding: var(--space-sm) 0;  /* 缩小padding */
}

.privacy-btn-agree {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-round);
  font-size: var(--font-size-md);  /* 32rpx（原来34rpx） */
  font-weight: var(--font-weight-medium);
  padding: var(--space-sm) 0;  /* 缩小padding */
  box-shadow: var(--shadow-primary);
}

.privacy-btn-agree::after {
  border: none;
}
