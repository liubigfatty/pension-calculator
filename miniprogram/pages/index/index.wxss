/* pages/index/index.wxss - 增强版（精致金融风格）*/

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #171717 0%, #2A2A2A 40%, #171717 100%);  /* 更精致的渐变 */
  padding: 0 40rpx 40rpx;  /* 更宽松的padding */
  position: relative;
  overflow: hidden;
}

/* 添加 subtle 纹理背景 */
.container::before {
  content: '';
  position: absolute;
  top: -30%;
  left: -30%;
  width: 160%;
  height: 160%;
  background: radial-gradient(circle at 50% 30%, rgba(139,115,85,0.04) 0%, transparent 70%);
  pointer-events: none;
}

/* 主视觉区域 */
.hero {
  width: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 140rpx;  /* 更宽松的顶部间距 */
  padding-bottom: 72rpx;
}

.logo-img {
  width: 420rpx;  /* 更大的logo */
  height: 320rpx;
  border-radius: 32rpx;  /* 更大的圆角 */
  box-shadow: 
    0 20rpx 60rpx rgba(0,0,0,0.35),  /* 主阴影 */
    0 8rpx 20rpx rgba(0,0,0,0.2),    /* 次阴影 */
    inset 0 1rpx 0 rgba(139,115,85,0.1);  /* 顶部高光 */
}

.hero-overlay {
  margin-top: 48rpx;
  text-align: center;
}

.brand-name {
  display: block;
  font-size: 56rpx;  /* 更大的品牌名 */
  font-weight: 700;
  color: #F5F3F0;  /* 暖白 */
  letter-spacing: 8rpx;  /* 更大的字间距 */
  text-shadow: 
    0 4rpx 16rpx rgba(0,0,0,0.4),  /* 主阴影 */
    0 1rpx 4rpx rgba(0,0,0,0.2);     /* 次阴影 */
  font-family: -apple-system, 'Helvetica Neue', 'PingFang SC', sans-serif;
}

.brand-slogan {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;  /* 更大的标语 */
  color: rgba(245,243,240,0.8);
  letter-spacing: 3rpx;
  font-weight: 300;
}

.brand-tagline {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(139,115,85,0.95);  /* 正元光 - 金色 */
  font-weight: 500;
  letter-spacing: 2rpx;
  padding: 8rpx 24rpx;
  background: rgba(139,115,85,0.08);
  border-radius: 24rpx;
  border: 1rpx solid rgba(139,115,85,0.12);
}

/* 核心优势 - 增强版 */
.advantages {
  width: 92%;
  background: rgba(255,255,255,0.06);  /* 更透亮的背景 */
  border-radius: 28rpx;  /* 更大的圆角 */
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 48rpx 32rpx;  /* 更宽松的padding */
  margin-top: 56rpx;
  backdrop-filter: blur(12px);  /* 更强的模糊 */
  border: 1rpx solid rgba(255,255,255,0.08);  /* 精致富质感边框 */
  box-shadow: 
    0 8rpx 32rpx rgba(0,0,0,0.15),  /* 主阴影 */
    inset 0 1rpx 0 rgba(255,255,255,0.05);  /* 顶部高光 */
}

.adv-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.adv-num {
  font-size: 48rpx;  /* 更大的数字 */
  font-weight: 700;
  color: #B8977D;  /* 正元光 - 金色 */
  letter-spacing: 1rpx;
}

.adv-label {
  font-size: 28rpx;  /* 更大的标签 */
  color: rgba(245,243,240,0.9);
  margin-top: 12rpx;
  font-weight: 400;
}

.adv-sub {
  font-size: 24rpx;
  color: rgba(245,243,240,0.55);
  margin-top: 6rpx;
}

.adv-divider {
  width: 1rpx;
  height: 96rpx;  /* 更高的divider */
  background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.18) 30%, rgba(255,255,255,0.18) 70%, transparent 100%);  /* 渐变divider */
}

/* 开始按钮 - 增强版 */
.btn-start {
  width: 88%;
  margin-top: 72rpx;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  box-shadow:
    0 8rpx 24rpx rgba(139,115,85,0.35),
    0 3rpx 10rpx rgba(139,115,85,0.2),
    inset 0 1rpx 0 rgba(255,255,255,0.1);
  position: relative;
  overflow: hidden;
  line-height: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.btn-text { 
  color: #FFFFFF;
  letter-spacing: 6rpx; 
  font-weight: 600;
  font-size: 32rpx;
}

.btn-arrow { 
  color: #FFFFFF;
  font-size: 40rpx; 
  line-height: 1; 
  margin-left: 12rpx;
  font-weight: 300;
}

/* 底部说明 */
.footer {
  position: fixed;
  bottom: 32rpx;
  left: 0;
  right: 0;
  text-align: center;
  padding: 0 48rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(245,243,240,0.35);
  letter-spacing: 0.5rpx;
}

/* 隐私协议弹窗 - 增强版 */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.65);  /* 更深的遮罩 */
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  backdrop-filter: blur(4px);  /* 添加模糊效果 */
}

.privacy-popup {
  width: 82%;
  background: #F4F0E8;  /* Creamy Off-White - 暖白 */
  border-radius: 32rpx;  /* 更大的圆角 */
  padding: 56rpx 44rpx;  /* 更宽松的padding */
  box-shadow: 
    0 20rpx 64rpx rgba(0,0,0,0.35),  /* 主阴影 */
    0 8rpx 24rpx rgba(0,0,0,0.2),    /* 次阴影 */
    inset 0 1rpx 0 rgba(255,255,255,0.5);  /* 顶部高光 */
  border: 1rpx solid rgba(213,206,195,0.5);  /* 精致富质感边框 */
}

.privacy-title {
  font-size: 40rpx;  /* 更大的标题 */
  font-weight: 700;
  color: #171717;  /* Deep Charcoal - 深色正文 */
  text-align: center;
  margin-bottom: 40rpx;
  letter-spacing: 2rpx;
}

.privacy-content {
  font-size: 32rpx;  /* 更大的内容 */
  color: #6C584B;  /* Warm Taupe - 暖棕 */
  line-height: 1.8;  /* 更宽松的行高 */
  margin-bottom: 48rpx;
  text-align: justify;
  letter-spacing: 0.5rpx;
}

.privacy-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;  /* 更大的间距 */
}

.privacy-btn-view {
  background: #FAF8F5;  /* 暖白输入框 */
  color: #8B7355;  /* 正元金 */
  border: 2rpx solid #8B7355;  /* 正元金边框 */
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  font-weight: 500;
  letter-spacing: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(139,115,85,0.1);  /* 轻微阴影 */
}

.privacy-btn-disagree {
  background: #F4F0E8;  /* Creamy Off-White - 暖白 */
  color: #6C584B;  /* Warm Taupe - 暖棕 */
  border: 2rpx solid #D5CEC3;  /* 暖棕边框 */
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.privacy-btn-agree {
  background: linear-gradient(135deg, #8B7355 0%, #A08566 50%, #8B7355 100%);  /* 更精致的渐变 */
  color: #F5F3F0;  /* 暖白 */
  border: none;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  padding: 28rpx 0;
  letter-spacing: 4rpx;
  box-shadow: 
    0 8rpx 24rpx rgba(139,115,85,0.35),  /* 主阴影 */
    inset 0 1rpx 0 rgba(255,255,255,0.1);     /* 顶部高光 */
}

.privacy-btn-agree::after {
  border: none;
}
