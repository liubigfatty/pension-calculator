<view class="page">
  <!-- 页眉 -->
  <view class="report-header">
    <text class="header-title">{{headerTitle}}</text>
    <text class="header-meta">{{headerMeta}}</text>
  </view>

  <!-- ① 个人情况 -->
  <view class="card">
    <view class="card-title">👤 个人情况</view>
    <view class="info-grid">
      <view class="info-item" wx:for="{{personalInfo}}" wx:key="label">
        <text class="ilbl">{{item.label}}</text>
        <text class="ival">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- ② 正常退休 -->
  <view class="card">
    <view class="card-title">📋 正常退休测算</view>
    <view class="summary-line">{{legalSummary}}</view>
    <view class="calc-detail" wx:for="{{legalCalc}}" wx:key="title">
      <view class="calc-step {{item.color}}">
        <text class="calc-title">{{item.title}}</text>
        <text class="calc-formula">{{item.formula}} = <text class="hl">{{item.amount}}</text></text>
      </view>
    </view>
    <view class="total-line">月基本养老金合计：<text class="total-amount">{{legalTotal}}</text></view>
  </view>

  <!-- ③ 弹性退休 -->
  <view wx:if="{{showFlex}}" class="card">
    <view class="card-title">⏰ 弹性提前退休测算</view>
    <view class="summary-line">{{flexSummary}}</view>
    <view class="calc-detail" wx:for="{{flexCalc}}" wx:key="title">
      <view class="calc-step {{item.color}}">
        <text class="calc-title">{{item.title}}</text>
        <text class="calc-formula">{{item.formula}} = <text class="hl">{{item.amount}}</text></text>
      </view>
    </view>
    <view class="total-line">月基本养老金合计：<text class="total-amount">{{flexTotal}}</text></view>
  </view>

  <!-- ④ 对比分析 -->
  <view wx:if="{{showFlex}}" class="card">
    <view class="card-title">⇄ 正常退休 vs 弹性提前 对比分析</view>
    <view class="cmp-detail">{{cmpDetail}}</view>
  </view>

  <!-- ⑤ 相关建议 -->
  <view class="card">
    <view class="card-title">💡 相关建议</view>
    <view class="suggestion" wx:for="{{suggestions}}" wx:key="title" data-color="{{item.color}}">
      <text class="sug-title">{{item.title}}</text>
      <text class="sug-text">{{item.text}}</text>
    </view>
  </view>

  <!-- ⑥ 免责 -->
  <view class="card">
    <view class="card-title">📋 估算依据与免责声明</view>
    <view class="disclaimer">
      <text>▎估算依据\n个人账户余额和平均缴费指数为截至填表时的实际数据。\n后续至退休前的缴费，按您填写的平均缴费指数延续估算。\n个人账户后续利息按 1.5%（2025年全国统一记账利率）逐年复利估算。\n社平工资增长率按 2.0%（基于近年各省平均增长率）估算。\n\n▎免责声明\n计发基数、记账利率、过渡系数等参数依据各省人社厅官方文件及国家统一公布数据，截至2026年6月。\n基于您自行填写的参保参数和现行养老金计发办法测算，实际退休待遇以退休时当地社保部门核定为准。\n报告基于当前政策计算，不覆盖养老保险政策可能的调整。报告中的分析与建议为通用性参考，不构成任何形式的投资或保险购买建议。\n您填写的参保参数仅用于本次测算，不会存储在服务器端，可放心使用。本平台及报告提供方对因使用本报告内容而产生的任何直接或间接损失不承担法律责任。</text>
    </view>
  </view>

  <!-- 微信咨询 -->
  <view class="card">
    <view class="card-title">💬 个性化咨询</view>
    <text class="consult-text">如果您的参保情况比较复杂（如存在断缴、特殊工种、多地参保等），或有其他社保规划需求，欢迎添加微信咨询：</text>
    <image class="qr-img" src="/assets/wechat-qr.jpg" mode="aspectFit"></image>
  </view>
</view>
