<view class="report-wrap">
  <view class="loading" wx:if="{{isLoading}}"><text>加载报告中...</text></view>

  <view wx:else class="report-scroll">

    <!-- ===== Hero 金额卡 ===== -->
    <view class="hero-card">
      <view class="hero-inner">
        <text class="hero-label">每月可领取养老金</text>
        <view class="hero-amount-row">
          <text class="hero-symbol">¥</text>
          <text class="hero-amount">{{legalTotalStr}}</text>
        </view>
        <view class="hero-tags">
          <text class="hero-tag">{{identity}} · {{provinceName}}{{cityLabel ? ' · ' + cityLabel : ''}}</text>
          <text class="hero-tag">{{legalAgeShow}}起领 · {{legalYearsShow}}</text>
        </view>
      </view>
      <view class="hero-glow"></view>
    </view>

    <!-- ===== 模块1：退休画像 ===== -->
    <view class="section">
      <view class="section-header" bindtap="toggleSection" data-key="profile">
        <text class="section-num">1</text>
        <text class="section-title">个人退休画像</text>
        <text class="section-arrow">{{showSection.profile ? '▾' : '▸'}}</text>
      </view>
      <view class="section-body" wx:if="{{showSection.profile}}">
        <view class="info-grid">
          <view class="info-item"><text class="info-label">参保地</text><text class="info-value">{{provinceName}}{{cityLabel ? ' · ' + cityLabel : ''}}</text></view>
          <view class="info-item"><text class="info-label">人员类型</text><text class="info-value">{{identity}}</text></view>
          <view class="info-item"><text class="info-label">法定退休年龄</text><text class="info-value highlight">{{legalAgeStr}}</text></view>
          <view class="info-item"><text class="info-label">退休时间</text><text class="info-value">{{legalDate}}</text></view>
          <view class="info-item"><text class="info-label">缴费年限</text><text class="info-value">{{legalYearsStr}}</text></view>
          <view class="info-item"><text class="info-label">缴费指数</text><text class="info-value">{{avgIndexStr}}</text></view>
          <view class="info-item"><text class="info-label">个人账户余额</text><text class="info-value highlight">{{personalBalanceStr}} 元</text></view>
          <view class="info-item"><text class="info-label">计发基数</text><text class="info-value">{{baseRetireStr}} 元</text></view>
        </view>
      </view>
    </view>

    <!-- ===== 模块2：方案对比 ===== -->
    <view class="section">
      <view class="section-header" bindtap="toggleSection" data-key="comparison">
        <text class="section-num">2</text>
        <text class="section-title">方案深度对比</text>
        <text class="section-arrow">{{showSection.comparison ? '▾' : '▸'}}</text>
      </view>
      <view class="section-body" wx:if="{{showSection.comparison}}">
        <view class="compare-cards">
          <view class="compare-card normal">
            <text class="compare-label">正常退休</text>
            <text class="compare-amount">{{legalTotalStr}}</text>
            <text class="compare-desc">/月 · {{legalAgeShow}}起领</text>
          </view>
          <view class="compare-card early" wx:if="{{flexTotalStr != '--'}}">
            <text class="compare-label">弹性提前退休</text>
            <text class="compare-amount">{{flexTotalStr}}</text>
            <text class="compare-desc">/月 · {{flexAgeShow}}起领</text>
          </view>
        </view>

        <view class="data-table">
          <view class="tr header"><text class="td name">对比项</text><text class="td num">正常退休</text><text class="td num early-color">弹性提前</text></view>
          <view class="tr"><text class="td name">退休年龄</text><text class="td num">{{legalAgeShow}}</text><text class="td num early-color">{{flexAgeShow}}</text></view>
          <view class="tr"><text class="td name">退休时间</text><text class="td num">{{legalDateShow}}</text><text class="td num early-color">{{flexDateShow}}</text></view>
          <view class="tr"><text class="td name">缴费年限</text><text class="td num">{{legalYearsShow}}</text><text class="td num early-color">{{flexYearsShow}}</text></view>
          <view class="tr"><text class="td name">计发月数</text><text class="td num">{{legalMonthsShow}}</text><text class="td num early-color">{{flexMonthsShow}}</text></view>
          <view class="tr"><text class="td name">月养老金</text><text class="td num">{{legalTotalStr}}</text><text class="td num early-color">{{flexTotalStr}}</text></view>
          <view class="tr"><text class="td name">年养老金</text><text class="td num">{{legalAnnualStr}}</text><text class="td num early-color">{{flexAnnualStr}}</text></view>
        </view>
      </view>
    </view>

    <!-- ===== 模块3：累计领取对比 ===== -->
    <view class="section" wx:if="{{cumulativeItems.length > 0}}">
      <view class="section-header" bindtap="toggleSection" data-key="cumulative">
        <text class="section-num">3</text>
        <text class="section-title">累计领取对比</text>
        <text class="section-arrow">{{showSection.cumulative ? '▾' : '▸'}}</text>
      </view>
      <view class="section-body" wx:if="{{showSection.cumulative}}">
        <view class="data-table">
          <view class="tr header"><text class="td name">领到年龄</text><text class="td num">正常退休</text><text class="td num early-color">弹性提前</text><text class="td num">差额</text></view>
          <view wx:for="{{cumulativeItems}}" wx:key="age">
            <view class="tr {{item.isNormalStart ? 'normal-start' : ''}} {{item.isBreakEven ? 'breakeven' : ''}}">
              <text class="td name">{{item.age}}岁{{item.isNormalStart ? '（正常起领）' : ''}}</text>
              <text class="td num">¥{{item.legalTotal}}</text>
              <text class="td num early-color">¥{{item.flexTotal}}</text>
              <text class="td num" style="{{item.isBreakEven ? 'color:#8B7355;font-weight:600' : (item.diff.indexOf('+')===0 ? 'color:#4A8C5C' : 'color:#D85A30')}}">{{item.diff}}</text>
            </view>
          </view>
        </view>
        <view class="breakeven-tip" wx:if="{{breakEvenAge > 0}}">盈亏平衡点：约 <text class="highlight">{{breakEvenAge}}岁</text> 后正常退休累计领取反超</view>
      </view>
    </view>

    <!-- ===== 模块4：退休建议 ===== -->
    <view class="section">
      <view class="section-header" bindtap="toggleSection" data-key="advice">
        <text class="section-num">4</text>
        <text class="section-title">退休策略建议</text>
        <text class="section-arrow">{{showSection.advice ? '▾' : '▸'}}</text>
      </view>
      <view class="section-body" wx:if="{{showSection.advice}}">

        <!-- 企业职工版 -->
        <view wx:if="{{adviceType == 'worker'}}">
          <view class="advice-card blue">
            <text class="advice-title">企业职工退休分析</text>
            <text class="advice-text">正常退休月养老金 <text class="highlight">{{legalTotalStr}}</text>，弹性提前 <text class="highlight">{{flexTotalStr}}</text>，每月差额约<text class="highlight">¥{{diffMonthly}}</text>元。</text>
          </view>

          <view class="feature-section">
            <text class="feature-title">关键差异分析</text>
            <view class="feature-item">
              <text class="feature-label">工资收入</text>
              <text class="feature-desc">正常退休多领约<text class="highlight">¥{{salary3year}}</text>元工资（按缴费基数估算），弹性提前退休后无工资收入</text>
            </view>
            <view class="feature-item">
              <text class="feature-label">住房公积金</text>
              <text class="feature-desc">正常退休继续缴存，单位和个人合计约<text class="highlight">¥{{fund3year}}</text>；弹性提前退休停缴</text>
            </view>
            <view class="feature-item">
              <text class="feature-label">医疗保险</text>
              <text class="feature-desc">{{medicareLabel}}职工医保缴费年限要求约{{medicareRequirement}}年（{{medicareYears}}年已{{medicareMet ? '满足' : '不足'}}），弹性提前退休后可直接享受退休医保待遇，无需补缴</text>
            </view>
            <view class="feature-item" wx:if="{{breakEvenAge > 0}}">
              <text class="feature-label">盈亏平衡</text>
              <text class="feature-desc">约<text class="highlight">{{breakEvenAge}}岁</text>前弹性提前累计领取更高，此后正常退休反超</text>
            </view>
          </view>

          <view class="advice-suggest blue-suggest">
            <text>建议：正常退休经济上明显更优（工资+公积金远超养老金差额），建议优先选正常退休。若身体有慢性病、家庭需要照顾或工作强度大，可考虑弹性提前。</text>
          </view>
        </view>

        <!-- 灵活就业版 -->
        <view wx:if="{{adviceType == 'flexible'}}">
          <view class="advice-card green">
            <text class="advice-title">灵活就业退休分析</text>
            <text class="advice-text">全部保费自费（费率20%），提前退休经济账：少缴保费约<text class="highlight">¥{{savePremium}}</text>元 + 早领养老金约<text class="highlight">¥{{earlyPension}}</text>元，合计好处约<text class="highlight">¥{{totalEarlyBenefit}}</text>元。</text>
          </view>

          <view class="feature-section">
            <text class="feature-title">关键差异分析</text>
            <view class="feature-item">
              <text class="feature-label">保费节省</text>
              <text class="feature-desc">弹性提前退休约省下<text class="highlight">¥{{savePremium}}</text>元保费（全自费20%，3年少缴）</text>
            </view>
            <view class="feature-item">
              <text class="feature-label">早领养老金</text>
              <text class="feature-desc">提前领取约<text class="highlight">{{earlyMonths}}</text>个月，多领约<text class="highlight">¥{{earlyPension}}</text>元</text>
            </view>
            <view class="feature-item">
              <text class="feature-label">回本分析</text>
              <text class="feature-desc">合计好处约<text class="highlight">¥{{totalEarlyBenefit}}</text>元，正常退休每月多领<text class="highlight">¥{{diffMonthly}}</text>元，需约<text class="highlight">{{paybackYears}}</text>年追平</text>
            </view>
            <view class="feature-item" wx:if="{{medicareYears > 0}}">
              <text class="feature-label">医疗保险</text>
              <text class="feature-desc">{{medicareLabel}}职工医保缴费年限要求约{{medicareRequirement}}年（{{medicareYears}}年），弹性提前退休后可直接享受退休医保待遇</text>
            </view>
          </view>

          <view class="advice-suggest green-suggest">
            <text>建议：灵活就业全部自费，弹性提前退休省下的保费+早领的养老金合计明显。若想早点休息或保费压力大，弹性提前更划算；若缴费基数低且身体好，可考虑正常退休。</text>
          </view>
        </view>

        <!-- 替代率分析 -->
        <view class="feature-section" style="margin-top:10px">
          <text class="feature-title">养老金替代率分析</text>
          <view class="rate-row">
            <text class="rate-label">月养老金</text>
            <text class="rate-value">{{legalTotalStr}}</text>
          </view>
          <view class="rate-row">
            <text class="rate-label">退休前月工资（按缴费基数推算）</text>
            <text class="rate-value">约¥{{estPreRetireSalary}}</text>
          </view>
          <view class="rate-row highlight-row">
            <text class="rate-label">替代率</text>
            <text class="rate-value highlight">{{replaceRate}}%</text>
          </view>
          <text class="rate-desc">替代率 = 月养老金 ÷ 推算退休前工资。{{replaceRateDesc}}</text>
        </view>

      </view>
    </view>

    <!-- ===== 模块5：缴费优化建议 ===== -->
    <view class="section" wx:if="{{showSection.optimization}}">
      <view class="section-header" bindtap="toggleSection" data-key="optimization">
        <text class="section-num">5</text>
        <text class="section-title">缴费优化建议</text>
        <text class="section-arrow">{{showSection.optimization ? '▾' : '▸'}}</text>
      </view>
      <view class="section-body" wx:if="{{showSection.optimization}}">

        <!-- 企业职工版 -->
        <view wx:if="{{adviceType == 'worker'}}">
          <view class="advice-card blue" style="margin-bottom:8px">
            <text class="advice-text">企业职工社保由单位依法缴纳，缴费基数按本人实际工资确定。建议确认单位是否按照实际工资足额申报，避免低基数缴费影响未来待遇。</text>
          </view>
        </view>

        <!-- 灵活就业版 -->
        <view wx:if="{{adviceType == 'flexible'}}">
          <text class="calc-desc" style="margin-bottom:8px">灵活就业可自主选择缴费档次，不同指数对养老金的影响如下（基于当前缴费年限估算）：</text>
          <view class="data-table">
            <view class="tr header"><text class="td name">缴费指数</text><text class="td num">月养老金</text><text class="td num">月增加</text></view>
            <view class="tr"><text class="td name">0.6</text><text class="td num">¥{{index06}}</text><text class="td num" style="color:#888">--</text></view>
            <view class="tr"><text class="td name">0.8</text><text class="td num">¥{{index08}}</text><text class="td num green-color">+¥{{index08inc}}</text></view>
            <view class="tr" style="background:#F0F5EE"><text class="td name">{{avgIndexStr}}（当前）</text><text class="td num">{{legalTotalStr}}</text><text class="td num green-color">+¥{{index10inc}}</text></view>
            <view class="tr"><text class="td name">1.5</text><text class="td num">¥{{index15}}</text><text class="td num green-color">+¥{{index15inc}}</text></view>
            <view class="tr"><text class="td name">2.0</text><text class="td num">¥{{index20}}</text><text class="td num green-color">+¥{{index20inc}}</text></view>
          </view>
          <text class="calc-desc" style="margin-top:6px">注：以上为基础养老金变化估算，实际总养老金差异更大（含个人账户部分）。</text>
        </view>

        <!-- 咨询引导语 -->
        <view class="consult-card">
          <text class="consult-text">如果您存在以下情况：</text>
          <text class="consult-item">• 社保有断档、多地缴纳未合并</text>
          <text class="consult-item">• 曾经企业缴、后来灵活就业，不清楚怎么衔接</text>
          <text class="consult-item">• 想了解补缴政策或提前退休规划</text>
          <text class="consult-item">• 想测算不同缴费方案对养老金的影响</text>
          <image class="consult-image" src="/images/consult-wechat.jpg" mode="widthFix" />
          <text class="consult-footer">长按识别二维码，添加客服微信咨询</text>
        </view>

      </view>
    </view>

    <!-- ===== 模块6：养老金计算明细 ===== -->
    <view class="section">
      <view class="section-header" bindtap="toggleSection" data-key="calculation">
        <text class="section-num">6</text>
        <text class="section-title">养老金计算明细</text>
        <text class="section-arrow">{{showSection.calculation ? '▾' : '▸'}}</text>
      </view>
      <view class="section-body" wx:if="{{showSection.calculation}}">
        <view class="calc-row"><text class="calc-label">基础养老金</text><text class="calc-amount">{{basicPensionStr}}</text></view>
        <text class="calc-desc">{{basicDesc}}</text>

        <view class="calc-row"><text class="calc-label">个人账户养老金</text><text class="calc-amount">{{personalPensionStr}}</text></view>
        <text class="calc-desc">{{personalDesc}}</text>

        <view class="calc-row" wx:if="{{extraPensionStr}}"><text class="calc-label">增发养老金（{{provinceName}}）</text><text class="calc-amount">{{extraPensionStr}}</text></view>
        <view class="extra-detail" wx:if="{{extraDetails.length > 0}}">
          <text class="extra-line" wx:for="{{extraDetails}}" wx:key="label">{{item.label}} → {{item.amount}}</text>
        </view>

        <view class="calc-total"><text>月养老金合计</text><text class="total-amount">{{totalPensionStr}}/月</text></view>
      </view>
    </view>

    <!-- ===== 免责 ===== -->
    <view class="disclaimer" wx:if="{{showSection.disclaimer}}">
      <text>本报告依据国务院渐进式延迟退休政策（国办发〔2025〕5号）及{{provinceName}}现行计发办法计算。个人账户余额为复利估算值，实际以社保系统查询为准。最终待遇以退休时社保部门核定结果为准。</text>
    </view>

    <view class="btn-bar">
      <button class="btn-save" bindtap="onSaveImage">保存报告到相册</button>
      <button class="btn-back" bindtap="onBack">返回结果</button>
    </view>
    <canvas type="2d" id="reportCanvas" class="reportWidget" style="position:absolute;left:-9999px;top:0;width:375px;height:4000px;"></canvas>
  </view>
</view>
