.page { padding-bottom: 40px; }

.report-header { text-align: center; padding: 24px 16px 12px; }
.header-title { font-size: 20px; font-weight: 700; display: block; }
.header-meta { font-size: 11px; color: #86868b; margin-top: 4px; display: block; }

.card-title { font-size: 15px; font-weight: 600; margin-bottom: 12px; }

.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.info-item { padding: 8px 12px; background: #f8f9fa; border-radius: 8px; }
.ilbl { font-size: 12px; color: #86868b; display: block; }
.ival { font-size: 14px; font-weight: 600; display: block; margin-top: 2px; }

.summary-line { font-size: 12px; color: #86868b; line-height: 1.8; padding: 8px 0; }

.calc-step { padding: 10px 12px; border-radius: 8px; margin-bottom: 6px; border-left: 4px solid; }
.calc-step.blue { border-color: #0071e3; background: #f0f7ff; }
.calc-step.green { border-color: #34c759; background: #f0fff4; }
.calc-step.orange { border-color: #ff9500; background: #fff8f0; }
.calc-step.purple { border-color: #af52de; background: #f8f0ff; }

.calc-title { font-size: 13px; font-weight: 600; display: block; margin-bottom: 2px; }
.calc-formula { font-size: 12px; color: #4a4a4a; font-family: monospace; }
.hl { color: #0071e3; font-weight: 600; }

.total-line { text-align: right; font-size: 16px; font-weight: 700; margin-top: 12px; padding-top: 12px; border-top: 1px solid #e5e5ea; }
.total-amount { color: #0071e3; }

.cmp-detail { font-size: 13px; line-height: 1.8; white-space: pre-wrap; }

.suggestion { padding: 12px 14px; border-radius: 8px; margin-bottom: 8px; border-left: 4px solid; }
.sug-title { font-size: 14px; font-weight: 600; display: block; margin-bottom: 4px; }
.sug-text { font-size: 13px; color: #4a4a4a; line-height: 1.7; display: block; }

.disclaimer text { font-size: 11px; color: #4a4a4a; line-height: 1.8; white-space: pre-wrap; display: block; }

.consult-text { font-size: 13px; color: #4a4a4a; line-height: 1.7; display: block; }
.qr-img { width: 160px; height: 160px; margin: 12px auto 0; display: block; border-radius: 8px; }
