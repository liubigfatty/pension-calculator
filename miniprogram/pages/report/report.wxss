/* ============================================================
   报告页面样式 v2 — 专业金融报告风格
   设计语言：深色 Hero 卡 + 金棕主色 + 层次分明 + 充足留白
   色板：
     主色    #8B7355（金棕）— 标题、强调、金额
     深色卡  #1A1A1A → #2D2D2D — Hero 金额区域
     页面底  #F7F5F2 — 温暖米白
     卡片底  #FFFFFF — 纯白卡片
     辅助底  #FAF8F6 — 次级信息区
     分割线  #EDE8DF
     成功绿  #3A8B5C — 弹性提前/正向数据
     警示橙  #D4783A — 差额/注意
============================================================ */

.report-wrap {
  min-height: 100vh;
  background: #F7F5F2;
  padding: 0 0 40px;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
  font-size: 14px;
}

.report-scroll {
  max-width: 700rpx;
  margin: 0 auto;
}

/* ========== Hero 金额卡 ========== */
.hero-card {
  position: relative;
  margin: 0;
  padding: 48rpx 32rpx 44rpx;
  background: linear-gradient(165deg, #1A1A1A 0%, #2D2D2D 100%);
  overflow: hidden;
}

.hero-inner {
  position: relative;
  z-index: 2;
}

.hero-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(184,151,125,0.9);
  letter-spacing: 2rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.hero-amount-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
}

.hero-symbol {
  font-size: 36rpx;
  font-weight: 700;
  color: #B8977D;
  margin-right: 6rpx;
}

.hero-amount {
  font-size: 80rpx;
  font-weight: 700;
  color: #B8977D;
  letter-spacing: -1rpx;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.hero-tags {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  flex-wrap: wrap;
}

.hero-tag {
  font-size: 22rpx;
  color: rgba(184,151,125,0.65);
  padding: 4rpx 16rpx;
  background: rgba(139,115,85,0.1);
  border-radius: 16rpx;
  border: 0.5px solid rgba(139,115,85,0.15);
}

/* Hero 底部光晕 */
.hero-glow {
  position: absolute;
  bottom: -60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 70%;
  height: 120rpx;
  background: radial-gradient(ellipse, rgba(139,115,85,0.08) 0%, transparent 70%);
  pointer-events: none;
}

/* ========== 模块通用 ========== */
.section {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx 24rpx 0;
  overflow: hidden;
  border: 0.5px solid #EDE8DF;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 0.5px solid #F3F0EC;
  cursor: pointer;
}

.section-num {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #8B7355 0%, #A08860 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  line-height: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  flex: 1;
  letter-spacing: 1rpx;
}

.section-arrow {
  font-size: 24rpx;
  color: #BBB;
}

.section-body {
  padding: 24rpx 28rpx 28rpx;
}

/* ========== 信息网格 ========== */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.info-item {
  background: #FAF8F6;
  border-radius: 12rpx;
  padding: 18rpx 12rpx;
  text-align: center;
  border: 0.5px solid #F0EDE8;
}

.info-label {
  font-size: 23rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 27rpx;
  font-weight: 600;
  color: #333;
}

.info-value.highlight {
  color: #8B7355;
  font-weight: 700;
}

/* ========== 对比卡片 ========== */
.compare-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.compare-card {
  flex: 1;
  text-align: center;
  padding: 24rpx 12rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

.compare-card.normal {
  background: linear-gradient(160deg, #FAFAFA 0%, #F5F3F0 100%);
  border: 1px solid #EDE8DF;
}

.compare-card.early {
  background: linear-gradient(160deg, #F5FAF6 0%, #EDF5EF 100%);
  border: 1px solid #C8E0D2;
}

.compare-label {
  font-size: 24rpx;
  color: #777;
  display: block;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.compare-amount {
  font-size: 46rpx;
  font-weight: 700;
  color: #222;
  display: block;
  line-height: 1.2;
}

.compare-card.early .compare-amount {
  color: #3A8B5C;
}

.compare-desc {
  font-size: 22rpx;
  color: #AAA;
  display: block;
  margin-top: 8rpx;
}

/* ========== 数据表格 ========== */
.data-table {
  width: 100%;
  font-size: 24rpx;
}

.tr {
  display: flex;
  border-bottom: 0.5px solid #F3F0EC;
  align-items: center;
}

.tr.header {
  background: #FAF8F6;
  font-weight: 600;
  color: #666;
  font-size: 23rpx;
}

.tr.breakeven {
  background: #FFF9EB;
}

.tr.normal-start {
  background: #EDEFF4;
  border-left: 6rpx solid #8B7355;
}

.td {
  padding: 18rpx 10rpx;
  display: flex;
  align-items: center;
}

.td.name {
  flex: 2.2;
  color: #555;
  font-weight: 500;
}

.td.num {
  flex: 1;
  justify-content: center;
  text-align: center;
  font-weight: 600;
  color: #333;
}

.td.num.early-color {
  color: #3A8B5C;
}

.td.num.green { color: #3A8B5C; }
.td.num.red { color: #D4783A; }
.td.num.note { font-size: 22rpx; color: #AAA; font-weight: 400; }

.breakeven-tip {
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #FFF9EB 0%, #FFF5DB 100%);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #8B7355;
  text-align: center;
  border: 0.5px solid #F0E0C0;
  font-weight: 500;
}

.highlight {
  color: #8B7355;
  font-weight: 700;
}

/* ========== 特色分析 / 建议 ========== */
.feature-section,
.advice-card {
  border-radius: 14rpx;
}

.feature-section {
  margin-top: 16rpx;
  padding: 22rpx 20rpx;
  background: #FAF8F6;
  border: 0.5px solid #F0EDE8;
}

.feature-title {
  font-size: 27rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  display: block;
  color: #333;
}

.feature-item {
  margin-bottom: 14rpx;
  padding-bottom: 14rpx;
  border-bottom: 0.5px solid #EDE8DF;
}

.feature-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.feature-label {
  font-size: 25rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.7;
  display: block;
}

/* 建议卡片 */
.advice-card {
  border-radius: 14rpx;
  padding: 22rpx;
  font-size: 26rpx;
  line-height: 1.8;
}

.advice-card.blue {
  background: linear-gradient(160deg, #F5F8FC 0%, #EDF2FA 100%);
  border: 0.5px solid #D4E0F0;
  color: #2A4A6A;
}

.advice-card.green {
  background: linear-gradient(160deg, #F4FAF6 0%, #E5F2EA 100%);
  border: 0.5px solid #C8DDD4;
  color: #2A5A3A;
}

.advice-title {
  font-weight: 700;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  display: block;
  color: #333;
}

.advice-text {
  display: block;
  margin-bottom: 10rpx;
}

.advice-suggest {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  line-height: 1.75;
  font-weight: 500;
}

.blue-suggest {
  background: linear-gradient(160deg, #E8F1FB 0%, #DCE8F7 100%);
  color: #0C3A6C;
  border: 0.5px solid #C5D8ED;
}

.green-suggest {
  background: linear-gradient(160deg, #E0F5EC 0%, #D0EEDA 100%);
  color: #0A5E46;
  border: 0.5px solid #B8DCC8;
}

/* 替代率 */
.rate-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 25rpx;
}

.rate-row.highlight-row {
  padding: 16rpx 0;
  border-top: 0.5px solid #EDE8DF;
  margin-top: 8rpx;
}

.rate-label { color: #888; }
.rate-value { font-weight: 700; color: #333; }
.rate-desc {
  font-size: 23rpx;
  color: #999;
  line-height: 1.7;
  margin-top: 12rpx;
  display: block;
}

.green-color { color: #3A8B5C; }

/* ========== 咨询引导 ========== */
.consult-card {
  margin-top: 20rpx;
  padding: 24rpx 20rpx;
  background: linear-gradient(160deg, #FFFBF0 0%, #FFF8E4 100%);
  border-radius: 14rpx;
  border: 0.5px solid #F0DCA0;
}

.consult-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #8B7355;
  display: block;
  margin-bottom: 12rpx;
}

.consult-item {
  font-size: 24rpx;
  color: #A08860;
  display: block;
  line-height: 1.8;
  padding-left: 4rpx;
}

.consult-footer {
  font-size: 24rpx;
  font-weight: 600;
  color: #8B7355;
  display: block;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 0.5px solid #F0DCA0;
}

.consult-image {
  width: 100%;
  max-width: 300rpx;
  height: auto;
  display: block;
  margin: 16rpx auto;
  border-radius: 12rpx;
}

/* ========== 计算明细 ========== */
.calc-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  align-items: baseline;
}

.calc-label {
  font-size: 27rpx;
  color: #444;
  font-weight: 500;
}

.calc-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
}

.calc-desc {
  font-size: 23rpx;
  color: #AAA;
  line-height: 1.7;
  margin-bottom: 8rpx;
  padding: 0 0 8rpx 0;
  display: block;
}

.extra-detail {
  padding: 12rpx 16rpx;
  background: #FAF8F6;
  border-radius: 10rpx;
  margin-bottom: 8rpx;
  border: 0.5px solid #F0EDE8;
}

.extra-line {
  font-size: 23rpx;
  color: #999;
  display: block;
  line-height: 1.8;
}

.calc-total {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0 0;
  border-top: 1.5px solid #EDE8DF;
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  align-items: baseline;
}

.total-amount {
  font-size: 34rpx;
  font-weight: 800;
  color: #8B7355;
  letter-spacing: 0.5rpx;
}

/* ========== 免责 ========== */
.disclaimer {
  margin: 28rpx 24rpx 0;
  padding: 22rpx 24rpx;
  background: #FAF8F6;
  border-radius: 14rpx;
  font-size: 23rpx;
  color: #AAA;
  line-height: 1.8;
  border: 0.5px solid #EDE8DF;
}

/* ========== 按钮 ========== */
.btn-bar {
  display: flex;
  gap: 20rpx;
  margin: 32rpx 24rpx 48px;
}

.btn-save {
  flex: 1;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #8B7355 0%, #A08860 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 29rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(139,115,85,0.25);
}

.btn-back {
  flex: 1;
  padding: 24rpx 0;
  background: #fff;
  color: #8B7355;
  border: 1.5px solid #8B7355;
  border-radius: 48rpx;
  font-size: 29rpx;
  font-weight: 600;
}
