/* 全局样式 */
page {
  background: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #1d1d1f;
  font-size: 15px;
  line-height: 1.5;
}

.card {
  background: #fff;
  border-radius: 16px;
  padding: 24px;
  margin: 12px 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,.06);
}

.btn-primary {
  height: 48px;
  line-height: 48px;
  background: #0071e3;
  color: #fff;
  border-radius: 12px;
  text-align: center;
  font-size: 16px;
  font-weight: 600;
  margin: 16px;
}

.btn-primary:active {
  background: #0066cc;
}

.btn-secondary {
  height: 44px;
  line-height: 44px;
  background: #e5e5ea;
  color: #1d1d1f;
  border-radius: 10px;
  text-align: center;
  font-size: 15px;
  margin: 8px 16px;
}

.tag {
  display: inline-block;
  background: #f0f0f5;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
  color: #86868b;
  margin: 4px;
}
