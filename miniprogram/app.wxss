/* app.wxss - 全局设计系统 v2.0 */

/* ============================================
   设计变量（CSS Custom Properties）
   ============================================ */

page {
  /* 颜色系统 - 正元品牌色板（校准到官方VI） */
  --color-primary: #8B7355;           /* 正元金（官方VI精确色值） */
  --color-primary-dark: #A08566;      /* 正元尊（深金色） */
  --color-primary-light: #FEF0D6;    /* 正元光-浅底（暖金） */

  --color-success: #07c160;
  --color-warning: #B8977D;          /* 正元光-警告（亮金色） */
  --color-danger: #c0392b;
  --color-info: #005F6B;            /* Subtle Teal - 强调 */
  
  --color-text-primary: #171717;      /* 纯黑（官方VI深色背景对应文字） */
  --color-text-secondary: #6C584B;  /* Warm Taupe - 暖棕（次要文字） */
  --color-text-hint: #A3A3A3;      /* Cool Gray - 提示文字 */
  --color-text-white: #FFFFFF;       /* 白色（深色背景用） */

  --color-bg-page: #F5F3F0;         /* 暖白 - 页面底 */
  --color-bg-card: #F4F0E8;        /* Creamy Off-White - 卡片底 */
  --color-bg-input: #FAF8F5;        /* 输入框底 - 暖白 */
  --color-bg-disabled: #E8E0D0;     /* 禁用态 - 暖灰 */

  --color-border: #D5CEC3;          /* 暖棕边框 - 浅 */
  --color-border-focus: #8B7355;     /* 正元金 - 聚焦边框 */
  
  /* 字体系统 - 优化：更紧凑 */
  --font-size-xs: 20rpx;    /* 辅助文字（缩小） */
  --font-size-sm: 24rpx;    /* 次要文字（缩小） */
  --font-size-base: 28rpx;  /* 正文（缩小） */
  --font-size-md: 32rpx;    /* 小标题（缩小） */
  --font-size-lg: 36rpx;    /* 标题（缩小） */
  --font-size-xl: 40rpx;   /* 大标题（缩小） */
  --font-size-xxl: 48rpx;  /* 首页品牌名（缩小，原来56rpx） */
  
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-bold: 700;
  
  --line-height-tight: 1.3;
  --line-height-normal: 1.6;
  --line-height-loose: 1.8;
  
  /* 间距系统 - 优化：更紧凑（基于4rpx） */
  --space-xs: 4rpx;      /* 4rpx（缩小） */
  --space-sm: 12rpx;     /* 12rpx（缩小） */
  --space-md: 20rpx;     /* 20rpx（缩小） */
  --space-lg: 28rpx;     /* 28rpx（缩小） */
  --space-xl: 40rpx;     /* 40rpx（缩小） */
  --space-xxl: 56rpx;    /* 56rpx（缩小） */
  
  /* 圆角系统 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-round: 50rpx;  /* 全圆角 */
  
  /* 阴影系统 */
  --shadow-sm: 0 2rpx 8rpx rgba(40,41,43,0.06);
  --shadow-md: 0 4rpx 16rpx rgba(40,41,43,0.10);
  --shadow-lg: 0 8rpx 32rpx rgba(40,41,43,0.14);
  --shadow-primary: 0 8rpx 32rpx rgba(139,115,85,0.30);  /* 正元金阴影 */
  
  /* 过渡动画 */
  --transition-fast: 0.2s ease;
  --transition-normal: 0.3s ease;
  
  /* 基础样式 */
  background-color: var(--color-bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: var(--line-height-normal);
}

/* ============================================
   全局容器
   ============================================ */

.container {
  padding: var(--space-lg);
  min-height: 100vh;
  box-sizing: border-box;
}

.step-container {
  padding: var(--space-xl) var(--space-lg);
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 200rpx;
}

/* ============================================
   标题系统
   ============================================ */

.page-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);
  display: block;
}

.page-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-xl);
  display: block;
  line-height: var(--line-height-tight);
}

.section-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
  display: block;
}

.section-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-md);
  display: block;
}

/* ============================================
   表单组件
   ============================================ */

.form-group {
  margin-bottom: var(--space-lg);
}

.form-label {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  margin-bottom: var(--space-sm);
  display: block;
}

.form-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
  margin-top: var(--space-xs);
  display: block;
  line-height: var(--line-height-tight);
}

.form-required::before {
  content: '*';
  color: var(--color-danger);
  margin-right: var(--space-xs);
}

/* 选择器（统一风格：灰底、全圆角） */
.picker-box {
  background: var(--color-bg-input);
  border: 2rpx solid var(--color-border);
  border-radius: 48rpx;
  padding: var(--space-md) var(--space-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  position: relative;
  transition: all var(--transition-fast);
}

.picker-box.selected {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
}

.picker-box:active {
  background: #eee;
}

.picker-box.placeholder {
  color: var(--color-text-hint);
}

.picker-arrow {
  position: absolute;
  right: var(--space-lg);
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-text-hint);
  font-size: var(--font-size-sm);
}

/* 输入框（统一风格：灰底、全圆角） */
.input-box {
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  border-radius: var(--radius-round);
  padding: var(--space-md) var(--space-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  width: 100%;
  box-sizing: border-box;
  transition: all var(--transition-fast);
}

.input-box:focus {
  background: var(--color-bg-card);
  border-color: var(--color-border-focus);
}

.input-box::placeholder {
  color: var(--color-text-hint);
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

.radio-item {
  flex: 1;
  min-width: 200rpx;
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  border-radius: var(--radius-round);
  padding: var(--space-md) var(--space-lg);
  text-align: center;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  transition: all var(--transition-fast);
}

.radio-item:active {
  background: #eee;
}

.radio-item.active {
  background: #8B7355;
  color: var(--color-text-white);
  border-color: #8B7355;
}

/* 日期选择器 */
.date-picker {
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  border-radius: var(--radius-round);
  padding: var(--space-md) var(--space-lg);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  transition: all var(--transition-fast);
}

/* ============================================
   按钮系统（优化：更紧凑）
   ============================================ */

/* 主按钮 - 正元金渐变 */
.btn-primary {
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-round);
  padding: var(--space-sm) 0;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  width: 100%;
  text-align: center;
  transition: all var(--transition-normal);
  position: relative;
  overflow: hidden;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-primary.disabled,
.btn-primary[disabled] {
  background: #ccc;
  color: #fff;
}

/* 次按钮 - 正元金边框 */
.btn-secondary {
  background: var(--color-bg-card);
  color: #8B7355;
  border: 2rpx solid #8B7355;
  border-radius: var(--radius-round);
  padding: var(--space-sm) 0;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  width: 100%;
  text-align: center;
  transition: all var(--transition-fast);
}

.btn-secondary:active {
  background: #FDF5E6;
}

/* 底部按钮固定区域 */
.btn-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-md);
  background: var(--color-bg-card);
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
}

.btn-area {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}

/* ============================================
   卡片系统（优化：更紧凑）
   ============================================ */

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-md);  /* 缩小padding */
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
}

.card-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);  /* 缩小margin */
  display: block;
}

.card-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);  /* 优化行高 */
}

/* ============================================
   提示框系统（优化：更紧凑）
   ============================================ */

.tip-box {
  display: flex;
  align-items: flex-start;
  padding: var(--space-sm) var(--space-md);
  background: #FEFCFA;
  border-radius: var(--radius-md);
  border-left: 6rpx solid #A08566;  /* 深金色边框（替代 Warm Taupe） */
  margin-bottom: var(--space-md);
}

.tip-icon {
  font-size: var(--font-size-sm);
  margin-right: var(--space-sm);
  flex-shrink: 0;
}

.tip-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);  /* 优化行高 */
  flex: 1;
}

/* ============================================
   进度条系统（优化：更紧凑）
   ============================================ */

.progress-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) 0;
  margin-bottom: var(--space-xl);
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.step-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-bg-input);
  border: 4rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
  margin-bottom: var(--space-xs);
  z-index: 1;
}

.progress-step.active .step-dot {
  background: #8B7355;
  border-color: #8B7355;
  color: var(--color-text-white);
}

.progress-step.done .step-dot {
  background: #8B7355;
  border-color: #8B7355;
  color: var(--color-text-white);
}

.step-line {
  position: absolute;
  top: 20rpx;
  left: 50%;
  width: 100%;
  height: 4rpx;
  background: var(--color-border);
  z-index: 0;
}

.progress-step:last-child .step-line {
  display: none;
}

.progress-step.done .step-line {
  background: var(--color-primary);
}

.step-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-hint);
}

.progress-step.active .step-label {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* ============================================
   结果展示系统（优化：更紧凑）
   ============================================ */

.result-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl);  /* 缩小padding */
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-md);
}

.result-amount {
  font-size: 64rpx;
  font-weight: var(--font-weight-bold);
  color: #8B7355;  /* 正元金 - 金额（校准） */
  text-align: center;
  display: block;
  margin-bottom: var(--space-md);
}

.result-unit {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-normal);
}

.result-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  text-align: center;
  display: block;
  margin-bottom: var(--space-xl);  /* 缩小margin */
}

.result-detail {
  border-top: 2rpx solid var(--color-border);
  padding-top: var(--space-lg);  /* 缩小padding */
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
}

.detail-label {
  font-size: var(--font-size-sm);  /* 缩小字号 */
  color: var(--color-text-secondary);
}

.detail-value {
  font-size: var(--font-size-sm);  /* 缩小字号 */
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

/* ============================================
   工具类
   ============================================ */

.text-center {
  text-align: center;
}

.text-primary {
  color: var(--color-primary);
}

.text-secondary {
  color: var(--color-text-secondary);
}

.text-hint {
  color: var(--color-text-hint);
}

.text-bold {
  font-weight: var(--font-weight-bold);
}

.mt-sm { margin-top: var(--space-sm); }
.mt-md { margin-top: var(--space-md); }
.mt-lg { margin-top: var(--space-lg); }
.mt-xl { margin-top: var(--space-xl); }

.mb-sm { margin-bottom: var(--space-sm); }
.mb-md { margin-bottom: var(--space-md); }
.mb-lg { margin-bottom: var(--space-lg); }
.mb-xl { margin-bottom: var(--space-xl); }

/* ============================================
   动画
   ============================================ */

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

.animate-fadeIn {
  animation: fadeIn var(--transition-normal);
}

.animate-slideUp {
  animation: slideUp var(--transition-normal);
}

.animate-pulse {
  animation: pulse 1.5s infinite;
}

/* ============================================
   无障碍
   ============================================ */

:focus {
  outline: 2rpx solid var(--color-primary);
  outline-offset: 4rpx;
}

/* 隐藏但保持可访问性 */
.sr-only {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  padding: 0;
  margin: -1rpx;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}
