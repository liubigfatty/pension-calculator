/* app.wxss - 全局样式 */

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 容器 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 步骤容器 */
.step-container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 200rpx;
}

/* 标题 */
.step-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 16rpx;
}

.step-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 48rpx;
}

/* 表单项 */
.form-group {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.form-required::before {
  content: '*';
  color: #e74c3c;
  margin-right: 8rpx;
}

/* 选择器 */
.picker-box {
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #333;
  position: relative;
}

.picker-box.placeholder {
  color: #999;
}

.picker-arrow {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #999;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.radio-item {
  flex: 1;
  min-width: 200rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
  transition: all 0.3s;
}

.radio-item.active {
  background: #07c160;
  color: #fff;
  border-color: #07c160;
}

/* 日期选择器 */
.date-picker {
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
}

/* 输入框 */
.input-box {
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 按钮 */
.btn-primary {
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx 0;
  font-size: 34rpx;
  font-weight: 500;
  width: 100%;
}

.btn-primary.disabled {
  background: #b0c4ff;
}

.btn-secondary {
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
  border-radius: 12rpx;
  padding: 28rpx 0;
  font-size: 34rpx;
  font-weight: 500;
  width: 100%;
  margin-bottom: 20rpx;
}

/* 底部按钮固定 */
.btn-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.08);
}
