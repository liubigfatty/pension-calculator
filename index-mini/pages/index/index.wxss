/* pages/index/index.wxss */
.picker {
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  color: #111827;
}

.seg {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.seg-item {
  flex: 1;
  min-width: 30%;
  text-align: center;
  padding: 18rpx 8rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  color: #374151;
  font-size: 26rpx;
}
.seg-item.on {
  background: #1d4ed8;
  color: #fff;
  font-weight: 600;
}

.row {
  display: flex;
  align-items: center;
  margin: 14rpx 0;
}
.lbl {
  width: 160rpx;
  color: #4b5563;
  font-size: 28rpx;
}
.inp {
  flex: 1;
  background: #f3f4f6;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.ta {
  width: 100%;
  min-height: 200rpx;
  background: #f3f4f6;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  font-family: Menlo, Consolas, monospace;
  box-sizing: border-box;
}

.sample-btn {
  text-align: center;
  color: #1d4ed8;
  font-size: 28rpx;
  padding: 16rpx 0 24rpx;
}

.inline {
  display: flex;
  align-items: center;
  flex: 1;
}
.inp-s {
  width: 120rpx;
  background: #f3f4f6;
  border-radius: 10rpx;
  padding: 16rpx 12rpx;
  font-size: 28rpx;
  text-align: center;
}
.sep {
  color: #6b7280;
  margin: 0 8rpx;
}
.link {
  color: #1d4ed8;
  font-size: 26rpx;
  margin: 14rpx 0;
}

/* 逐年明细逐行表单（年份/月数自动生成，只填基数） */
.yr-head, .yr-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}
.yr-head {
  color: #6b7280;
  font-size: 24rpx;
}
.yr-c1 { flex: 1; }
.yr-c2 { flex: 1; }
.yr-c3 { flex: 1.5; }
.yr-text {
  font-size: 26rpx;
  text-align: center;
  color: #374151;
}
.yr-inp {
  background: #f3f4f6;
  border-radius: 10rpx;
  padding: 14rpx 8rpx;
  font-size: 26rpx;
  text-align: center;
  margin-right: 10rpx;
}
.gen-btn {
  text-align: center;
  color: #1d4ed8;
  font-size: 26rpx;
  padding: 14rpx 0;
  border: 1rpx solid #c7d2fe;
  border-radius: 10rpx;
  margin-top: 12rpx;
  background: #eef2ff;
}
