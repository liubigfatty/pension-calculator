/* pages/index/index.wxss */
.picker {
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  color: #111827;
}

.row {
  display: flex;
  align-items: center;
  margin: 14rpx 0;
}
.lbl {
  width: 160rpx;
  color: #4b5563;
  font-size: 28rpx;
}
.inp {
  flex: 1;
  background: #f3f4f6;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.inline {
  display: flex;
  align-items: center;
  flex: 1;
}
.inp-s {
  width: 120rpx;
  background: #f3f4f6;
  border-radius: 10rpx;
  padding: 16rpx 12rpx;
  font-size: 28rpx;
  text-align: center;
}
.sep {
  color: #6b7280;
  margin: 0 8rpx;
}

/* 逐年缴费清单 */
.list-tip {
  color: #6b7280;
  font-size: 24rpx;
  margin: 18rpx 0 6rpx;
  line-height: 1.5;
}
.yr-head, .yr-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}
.yr-head {
  color: #6b7280;
  font-size: 22rpx;
}
.yr-c1 { flex: 1; }
.yr-c2 { flex: 1; }
.yr-c3 { flex: 1.6; }
.yr-c4 { width: 48rpx; text-align: center; }
.yr-text {
  font-size: 26rpx;
  text-align: center;
  color: #374151;
}
.yr-inp {
  background: #f3f4f6;
  border-radius: 10rpx;
  padding: 14rpx 8rpx;
  font-size: 26rpx;
  text-align: center;
  margin-right: 8rpx;
}
.yr-del {
  color: #ef4444;
  font-size: 30rpx;
}

.gen-btn {
  text-align: center;
  color: #1d4ed8;
  font-size: 26rpx;
  padding: 14rpx 0;
  border: 1rpx solid #c7d2fe;
  border-radius: 10rpx;
  margin-top: 14rpx;
  background: #eef2ff;
}
.add-btn {
  text-align: center;
  color: #1d4ed8;
  font-size: 26rpx;
  padding: 14rpx 0;
  margin-top: 10rpx;
}
.sample-btn {
  text-align: center;
  color: #6b7280;
  font-size: 26rpx;
  padding: 18rpx 0 8rpx;
}

.btn-primary {
  margin-top: 24rpx;
  background: #1d4ed8;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
}
