/* pages/index/index.wxss — 与养老金主程序（正元金）统一 */

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 32rpx;
  box-sizing: border-box;
}

/* 表单卡片 */
.form-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 40rpx 36rpx 36rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
}

.form-card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0EDE8;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}
.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

/* 选择器胶囊（与主程序 picker-box 一致） */
.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-input);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-round);
  padding: 26rpx 28rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  transition: all 0.2s ease;
}
.picker-box.selected {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
}
.picker-value {
  flex: 1;
}
.picker-arrow {
  font-size: 20rpx;
  color: var(--color-text-hint);
  margin-left: 12rpx;
}

/* 输入框胶囊（与主程序 input-wrap 一致） */
.input-wrap {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--color-bg-input);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-round);
  padding: 0 28rpx;
  height: 88rpx;
  box-sizing: border-box;
}
.input-wrap:focus-within {
  border-color: var(--color-primary);
  background: #FFFFFF;
}
.input-field {
  flex: 1;
  width: 100%;
  height: 100%;
  font-size: 30rpx;
  color: var(--color-text-primary);
  background: transparent;
  line-height: 88rpx;
  text-align: center;
}
.input-suffix {
  font-size: 26rpx;
  color: var(--color-text-hint);
  margin-left: 8rpx;
}

/* 并排日期（年/月） */
.date-row {
  display: flex;
  gap: 20rpx;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-hint);
  line-height: 1.5;
  margin-top: 12rpx;
}

/* 断缴提示（暖金） */
.warn {
  background: #FFF7ED;
  color: #C2410C;
  border: 1rpx solid #FED7AA;
  border-radius: 12rpx;
  padding: 18rpx 22rpx;
  font-size: 25rpx;
  line-height: 1.6;
  margin-top: 14rpx;
}

/* 逐年缴费明细表 */
.yr-head {
  display: flex;
  align-items: center;
  color: var(--color-text-hint);
  font-size: 22rpx;
  margin-bottom: 8rpx;
}
.yr-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}
.yr-c1 { flex: 1; }
.yr-c2 { flex: 1; }
.yr-c3 { flex: 1.6; }
.yr-c4 { width: 48rpx; text-align: center; }

.yr-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
}
.yr-wrap {
  height: 64rpx;
  margin-right: 10rpx;
}
.yr-field {
  line-height: 64rpx;
  font-size: 24rpx;
}
.yr-del {
  color: var(--color-danger);
  font-size: 30rpx;
}

/* 操作按钮 */
.gen-btn {
  text-align: center;
  color: var(--color-primary);
  font-size: 26rpx;
  padding: 16rpx 0;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-round);
  margin-top: 18rpx;
  background: rgba(139,115,85,0.06);
}
.add-btn {
  text-align: center;
  color: var(--color-primary);
  font-size: 26rpx;
  padding: 16rpx 0;
  margin-top: 12rpx;
}
.sample-btn {
  text-align: center;
  color: var(--color-text-hint);
  font-size: 26rpx;
  padding: 16rpx 0 0;
}
