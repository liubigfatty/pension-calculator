<view class="container">

  <view class="row">
    <text class="lbl">参保地</text>
    <picker mode="selector" range="{{provinces}}" range-key="name" value="{{provIndex}}" bindchange="onProvChange">
      <view class="picker">{{provinces[provIndex].name}} ▾</view>
    </picker>
    <view class="warn" wx:if="{{gapHint}}">{{gapHint}}</view>
  </view>

  <view class="row">
    <text class="lbl">首次缴费年月</text>
    <view class="inline">
      <input class="inp-s" value="{{startYear}}" data-field="startYear" bindinput="onInput" placeholder="年" type="number"/>
      <text class="sep">年</text>
      <input class="inp-s" value="{{startMonth}}" data-field="startMonth" bindinput="onInput" placeholder="月" type="number"/>
      <text class="sep">月</text>
    </view>
  </view>

  <view class="row">
    <text class="lbl">缴费年度范围</text>
    <view class="inline">
      <picker mode="selector" range="{{yearRange}}" value="{{listStartIdx < 0 ? 0 : listStartIdx}}" data-field="start" bindchange="onRangeChange">
        <view class="picker-s">{{listStartYear || '起始'}}年 ▾</view>
      </picker>
      <text class="sep">至</text>
      <picker mode="selector" range="{{yearRange}}" value="{{listEndIdx}}" data-field="end" bindchange="onRangeChange">
        <view class="picker-s">{{listEndYear || '截止'}}年 ▾</view>
      </picker>
    </view>
  </view>

  <view class="list-tip">逐年缴费明细（按上方「缴费年度范围」自动生成年份行；有缴的年份填「月均缴费基数」，没缴的年份留空）</view>

  <view class="yr-head">
    <text class="yr-c1">年份</text>
    <text class="yr-c2">月数</text>
    <text class="yr-c3">月均缴费基数</text>
    <text class="yr-c4"></text>
  </view>
  <view class="yr-row" wx:for="{{yearlyList}}" wx:key="year">
    <text class="yr-text yr-c1">{{item.year}}年</text>
    <input class="yr-inp yr-c2" value="{{item.months}}" data-idx="{{index}}" data-sub="months" bindinput="onYearlyInput" type="number"/>
    <input class="yr-inp yr-c3" value="{{item.baseAvg}}" data-idx="{{index}}" data-sub="baseAvg" bindinput="onYearlyInput" placeholder="如4980" type="digit"/>
    <text class="yr-del yr-c4" data-idx="{{index}}" bindtap="delRow">✕</text>
  </view>

  <view class="gen-btn" bindtap="genYearly">↻ 按年度范围重新生成年份行</view>
  <view class="add-btn" bindtap="addYear">＋ 添加一年</view>

  <view class="sample-btn" bindtap="fillSample">填入示例数据（吉林 1998-2022）</view>

  <button class="btn-primary" bindtap="calc" loading="{{loading}}" disabled="{{loading}}">计算平均缴费指数</button>

</view>
