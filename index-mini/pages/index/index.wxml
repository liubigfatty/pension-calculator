<!--pages/index/index.wxml-->
<view class="container">

  <!-- 基础信息卡片 -->
  <view class="form-card">
    <!-- 参保地 -->
    <view class="form-item">
      <text class="form-label">参保地</text>
      <picker mode="selector" range="{{provinces}}" range-key="name" value="{{provIndex}}" bindchange="onProvChange">
        <view class="picker-box {{provIndex >= 0 ? 'selected' : ''}}">
          <text class="picker-value">{{provinces[provIndex].name}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
      <view class="warn" wx:if="{{gapHint}}">{{gapHint}}</view>
    </view>

    <!-- 首次缴费年月 -->
    <view class="form-item">
      <text class="form-label">首次缴费年月</text>
      <view class="date-row">
        <view class="input-wrap">
          <input class="input-field" value="{{startYear}}" data-field="startYear" bindinput="onInput" placeholder="年" type="number"/>
          <text class="input-suffix">年</text>
        </view>
        <view class="input-wrap">
          <input class="input-field" value="{{startMonth}}" data-field="startMonth" bindinput="onInput" placeholder="月" type="number"/>
          <text class="input-suffix">月</text>
        </view>
      </view>
      <text class="form-hint">清单自动从首年起铺到今年（{{curYear}}年）；有缴的年份填月均缴费基数，没缴的年份留空。</text>
    </view>
  </view>

  <!-- 逐年缴费明细卡片 -->
  <view class="form-card">
    <text class="form-card-title">逐年缴费明细</text>

    <view class="yr-head">
      <text class="yr-c1">年份</text>
      <text class="yr-c2">月数</text>
      <text class="yr-c3">月均缴费基数</text>
      <text class="yr-c4"></text>
    </view>

    <view class="yr-row" wx:for="{{yearlyList}}" wx:key="year">
      <text class="yr-text yr-c1">{{item.year}}年</text>
      <view class="input-wrap yr-wrap yr-c2">
        <input class="input-field yr-field" value="{{item.months}}" data-idx="{{index}}" data-sub="months" bindinput="onYearlyInput" type="number"/>
      </view>
      <view class="input-wrap yr-wrap yr-c3">
        <input class="input-field yr-field" value="{{item.baseAvg}}" data-idx="{{index}}" data-sub="baseAvg" bindinput="onYearlyInput" placeholder="如4980" type="digit"/>
      </view>
      <text class="yr-del yr-c4" data-idx="{{index}}" bindtap="delRow">✕</text>
    </view>

    <view class="gen-btn" bindtap="genYearly">↻ 重新生成（首年 → 今年）</view>
    <view class="add-btn" bindtap="addYear">＋ 添加一年</view>
    <view class="sample-btn" bindtap="fillSample">填入示例数据（吉林 1998-2022）</view>
  </view>

  <button class="btn-primary" bindtap="calc" loading="{{loading}}" disabled="{{loading}}">计算平均缴费指数</button>

</view>
