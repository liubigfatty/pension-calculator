<!--pages/index/index.wxml-->
<view class="container">

  <!-- 基础信息卡片 -->
  <view class="form-card">
    <!-- 参保地 -->
    <view class="form-item">
      <text class="form-label">参保地</text>
      <picker mode="selector" range="{{provinces}}" range-key="name" value="{{provIndex}}" bindchange="onProvChange">
        <view class="picker-box {{provIndex >= 0 ? 'selected' : ''}}">
          <text class="picker-value">{{provinces[provIndex].name}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
      <view class="warn" wx:if="{{gapHint}}">{{gapHint}}</view>
    </view>

    <!-- 首次缴费年月（复用养老金主程序的年月时间选择器） -->
    <view class="form-item">
      <text class="form-label">首次缴费年月</text>
      <picker mode="date" fields="month" value="{{startDate}}" start="1990-01" end="{{today}}" bindchange="onStartDateChange">
        <view class="picker-box {{startDate ? 'selected' : ''}}">
          <text class="picker-value">{{startDate || '请选择首次缴费年月'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 逐年缴费明细卡片 -->
  <view class="form-card">
    <text class="form-card-title">逐年缴费明细（未缴年份留空）</text>

    <view class="yr-head">
      <text class="yr-c1">年份</text>
      <text class="yr-c2">月数</text>
      <text class="yr-c3">月均缴费基数</text>
    </view>

    <view class="yr-row" wx:for="{{yearlyList}}" wx:key="year">
      <text class="yr-text yr-c1">{{item.year}}年</text>
      <view class="input-wrap yr-wrap yr-c2">
        <input class="input-field yr-field" value="{{item.months}}" data-idx="{{index}}" data-sub="months" bindinput="onYearlyInput" type="number"/>
      </view>
      <view class="input-wrap yr-wrap yr-c3">
        <input class="input-field yr-field" value="{{item.baseAvg}}" data-idx="{{index}}" data-sub="baseAvg" bindinput="onYearlyInput" placeholder="如4980" type="digit"/>
      </view>
    </view>
  </view>

  <button class="btn-primary" bindtap="calc" loading="{{loading}}" disabled="{{loading}}">计算平均缴费指数</button>

</view>
