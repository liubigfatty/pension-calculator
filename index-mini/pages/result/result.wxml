<view class="container">

  <!-- 正向结果 -->
  <view class="card" wx:if="{{hasForward}}">
    <view class="title">平均缴费工资指数（正向）</view>
    <view class="metric">
      <text class="m-label">本人平均缴费工资指数</text>
      <text class="m-value big">{{avgIndex}}</text>
    </view>
    <view class="metric">
      <text class="m-label">个人账户余额（估算）</text>
      <text class="m-value">¥{{accountBalance}}</text>
    </view>
    <view class="metric">
      <text class="m-label">累计缴费</text>
      <text class="m-value">{{totalMonths}} 个月（{{totalYears}} 年）</text>
    </view>
    <view class="hint">{{forwardSource}}</view>
    <view class="warn" wx:if="{{gapNote}}">{{gapNote}}</view>
    <view class="hint strong" wx:if="{{forwardIsCurrent}}">当下指数 = 当前基数 ÷ 当前社平 = {{forwardCurrentIndex}}，已作为平均缴费指数反推各年基数并算出余额。</view>
  </view>

  <!-- 反推结果 -->
  <view class="card" wx:if="{{hasInfer}}">
    <view class="title">推算平均指数（反推）</view>
    <view class="metric">
      <text class="m-label">推算本人平均缴费工资指数</text>
      <text class="m-value big">{{inferredIndex}}</text>
    </view>
    <view class="metric">
      <text class="m-label">对应账户余额</text>
      <text class="m-value">¥{{calculatedBalance}}</text>
    </view>
    <view class="metric">
      <text class="m-label">收敛状态</text>
      <text class="m-value">{{converged ? '已收敛' : '未完全收敛'}}{{residual ? '（误差'+residual+'）' : ''}}</text>
    </view>
  </view>

  <!-- 两者对照提示 -->
  <view class="note" wx:if="{{hasForward && hasInfer}}">
    正向与反推两个指数若接近，说明数据吻合；差异较大时建议核对输入。
  </view>

  <!-- 逐年明细 -->
  <view class="card" wx:if="{{hasForward && detail.length > 0}}">
    <view class="title">逐年明细</view>
    <view class="tbl">
      <view class="tr th">
        <text class="td">年份</text>
        <text class="td">月数</text>
        <text class="td">月均基数</text>
        <text class="td">指数</text>
        <text class="td">年末余额</text>
      </view>
      <view class="tr" wx:for="{{detail}}" wx:key="year">
        <text class="td">{{item.year}}</text>
        <text class="td">{{item.months}}</text>
        <text class="td">{{item.baseAvg}}</text>
        <text class="td">{{item.index}}</text>
        <text class="td">{{item.balance}}</text>
      </view>
    </view>
  </view>

  <button class="btn-primary" bindtap="back">返回修改</button>
</view>
