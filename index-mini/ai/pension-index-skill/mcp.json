{
  "apis": [
    {
      "name": "calculatePensionIndex",
      "description": "根据用户提供的参保地和逐年缴费基数，计算本人平均缴费工资指数与个人账户余额。当用户想了解自己的养老金缴费水平、平均缴费指数、个人账户累计金额时使用。",
      "_meta": {
        "ui": {
          "componentPath": "ai/pension-index-skill/components/result-card",
          "pagePath": "pages/result/result"
        }
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "province": {
            "type": "string",
            "description": "参保地省份，如「吉林省」「浙江」「北京」。支持中文省名或拼音代码（jilin/zhejiang/beijing）。"
          },
          "yearlyData": {
            "type": "array",
            "description": "逐年缴费明细数组，每项包含 year(年份)、months(该年缴费月数，通常12)、baseAvg(该年月均缴费基数，元/月)。未缴费年份可省略或 baseAvg 设 0。",
            "items": {
              "type": "object",
              "properties": {
                "year": { "type": "number", "description": "缴费年份，如 2022" },
                "months": { "type": "number", "description": "该年实际缴费月数，1-12" },
                "baseAvg": { "type": "number", "description": "该年月均缴费工资基数（元/月）" }
              },
              "required": ["year", "months", "baseAvg"]
            }
          }
        },
        "required": ["province", "yearlyData"]
      },
      "outputSchema": {}
    }
  ],
  "components": [
    {
      "path": "ai/pension-index-skill/components/result-card",
      "relatedPage": "/pages/result/result",
      "expirable": false
    }
  ]
}
