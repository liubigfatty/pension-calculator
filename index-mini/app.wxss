/* app.wxss 全局样式 — 与养老金主程序统一为正元金设计系统 */

page {
  /* 颜色系统 - 正元品牌色板 */
  --color-primary: #8B7355;
  --color-primary-dark: #A08566;
  --color-primary-light: #FEF0D6;

  --color-success: #07c160;
  --color-warning: #B8977D;
  --color-danger: #c0392b;
  --color-info: #005F6B;

  --color-text-primary: #171717;
  --color-text-secondary: #6C584B;
  --color-text-hint: #A3A3A3;
  --color-text-white: #FFFFFF;

  --color-bg-page: #F5F3F0;
  --color-bg-card: #FFFFFF;
  --color-bg-input: #FAF8F5;
  --color-bg-disabled: #E8E0D0;

  --color-border: #D5CEC3;
  --color-border-focus: #8B7355;

  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-round: 50rpx;

  --shadow-card: 0 4rpx 20rpx rgba(40,41,43,0.06);
  --shadow-primary: 0 8rpx 32rpx rgba(139,115,85,0.30);

  background-color: var(--color-bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

/* 表单卡片（与主程序一致） */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 40rpx 36rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

/* 主按钮 - 金色胶囊（与主程序 btn-submit 一致） */
.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #8B7355 0%, #A08566 100%);
  color: #FFFFFF !important;
  border: none;
  border-radius: var(--radius-round);
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: var(--shadow-primary);
  line-height: normal;
}
.btn-primary::after { border: none; }
.btn-primary[disabled] {
  background: #C9BBA8;
  box-shadow: none;
}

.hint {
  font-size: 24rpx;
  color: var(--color-text-hint);
  line-height: 1.6;
}
.hint.strong,
.strong {
  color: #8B7355;
  font-weight: 600;
}
