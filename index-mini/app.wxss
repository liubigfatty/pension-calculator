/* app.wxss 全局样式 */
page {
  background: #f5f6fa;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Helvetica, sans-serif;
  color: #1f2937;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: #1d4ed8;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 22rpx 0;
  text-align: center;
}

.btn-primary[disabled] {
  background: #9ca3af;
}

.hint {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.hint.strong,
.strong {
  color: #b45309;
  font-weight: 600;
}
